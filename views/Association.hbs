    <script>
        const searchassociationInput = document.getElementById('globalGroupSearch');
        const associationdropdown = document.getElementById('associationsDropdown');
        const content = document.getElementById('dropdownContent');

        if (!searchassociationInput || !associationdropdown || !content) {
            console.error('Search elements not found! Check IDs.');
        }

        searchassociationInput.addEventListener('input', function () {
            const query = this.value.trim();
            console.log('Search query:', query); // ← Check this in browser console!

            // Hide dropdown if query too short
            if (query.length < 2) {
                associationdropdown.classList.add('hidden');
                return;
            }

            // Show loading state
            content.innerHTML = '<div class="px-4 py-3 text-gray-500">Searching...</div>';
            associationdropdown.classList.remove('hidden');

            fetch(`/Groups/search?query=${encodeURIComponent(query)}`)
                .then(response => {
                    if (!response.ok) throw new Error('Network error');
                    return response.json();
                })
                .then(data => {
                    console.log('Search data received:', data); // ← Check this in browser console!
                    associationdropdown.classList.remove('hidden');
                    console.log('Dropdown shown', associationdropdown); // ← Check this in browser console!
                    if (!data.success || (!data.myGroups?.length && !data.discoverGroups?.length)) {
                        content.innerHTML = '<div class="px-4 py-3 text-center text-gray-500">No groups found</div>';
                        return;
                    }

                    let html = '';

                    if (data.myGroups?.length) {
                        html += '<div class="px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Your Groups</div>';
                        data.myGroups.forEach(g => {
                            html += `
                    <a href="/association/group/${g._id}" class="block px-4 py-3 hover:bg-gray-100 flex items-center gap-3">
                        <img src="${g.g_cover || '/assets/images/demo.jpg'}" class="w-10 h-10 rounded object-cover" alt=""/>
                        <div>
                            <div class="font-medium text-gray-900">${g.g_name}</div>
                            <div class="text-xs text-gray-500">${g.total_mem} members</div>
                        </div>
                    </a>`;
                        });
                    }

                    if (data.discoverGroups?.length) {
                        html += '<div class="px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Discover</div>';
                        data.discoverGroups.forEach(g => {
                            html += `
                    <a href="/association/group/${g._id}" class="block px-4 py-3 hover:bg-gray-100 flex items-center gap-3">
                        <img src="${g.g_cover || '/assets/images/demo.jpg'}" class="w-10 h-10 rounded object-cover" alt=""/>
                        <div>
                            <div class="font-medium text-gray-900">${g.g_name}</div>
                            <div class="text-xs text-gray-500">${g.total_mem} members • ${g.g_type}</div>
                        </div>
                    </a>`;
                        });
                    }

                    content.innerHTML = html;
                    // Force show again in case something hid it
                    associationdropdown.classList.remove('hidden');
                })
                .catch(err => {
                    console.error('Search error:', err);
                    content.innerHTML = '<div class="px-4 py-3 text-red-500">Error loading results</div>';
                });
        });

        // Hide associationdropdown when clicking outside
        document.addEventListener('click', function (e) {
            if (!searchInput.contains(e.target) && !associationdropdown.contains(e.target)) {
                associationdropdown.classList.add('hidden');
            }
        });


        // Optional: Hide when pressing Escape
        searchInput.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                associationdropdown.classList.add('hidden');
                this.blur();
            }
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {

            document.querySelectorAll('.group-card').forEach(card => {
                card.style.cursor = 'pointer';
                card.addEventListener('click', (e) => {

                    if (e.target.closest('a, button')) {
                        return;
                    }

                    const groupId = card.dataset.groupId;
                    if (groupId) {
                        window.location.href = `/Groups/group-info/${groupId}`;
                    }
                });
            });

            document.querySelectorAll('.group-title').forEach(title => {
                title.style.cursor = 'pointer';
            });
        });
    </script>
