<button class="mobile-toggle" id="mobileToggle">
  <i class="fas fa-bars"></i>
</button>

 <script>
  const sidebar = document.getElementById('sidebar');
  const sidebarToggle = document.getElementById('sidebarToggle');
  const toggleIcon = document.getElementById('toggleIcon');
  const mobileToggle = document.getElementById('mobileToggle');

  if (sidebarToggle) {
    sidebarToggle.addEventListener('click', () => {
      sidebar.classList.toggle('collapsed');
      toggleIcon.classList.toggle('fa-angle-left');
      toggleIcon.classList.toggle('fa-angle-right');
      if (sidebar.classList.contains('collapsed')) {
        toggleIcon.classList.replace('fa-angle-left', 'fa-angle-right');
      } else {
        toggleIcon.classList.replace('fa-angle-right', 'fa-angle-left');
      }
    });
  }

  // Mobile toggle (off-canvas)
  if (mobileToggle) {
    mobileToggle.addEventListener('click', () => {
      sidebar.classList.toggle('open-mobile');
      document.body.classList.toggle('sidebar-open-mobile');
    });
  }

  // Close mobile sidebar when clicking a link
  document.querySelectorAll('.sidebar-menu a').forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 992) {
        sidebar.classList.remove('open-mobile');
        document.body.classList.remove('sidebar-open-mobile');
      }
    });
  });
  // Hide loader on page load (this runs on every page after DOM is ready)
  document.addEventListener('DOMContentLoaded', function () {
    const loader = document.getElementById('pageLoader');
    if (loader) {
      loader.classList.remove('show');
      loader.classList.add('hiding');
      setTimeout(() => {
        loader.style.display = 'none';
        loader.classList.remove('hiding');
      }, 500); // Match transition duration
    }
    highlightActiveMenu();
  });

  // Show loader on sidebar link clicks (this handles navigation from any page)
  document.addEventListener('click', function (event) {
    // Check if the clicked element is a sidebar link (adjust selector as needed for your sidebar)
    if (event.target.closest('.sidebar-menu a') || event.target.closest('.submenu a')) {
      const loader = document.getElementById('pageLoader');
      if (loader) {
        loader.style.display = 'flex';
        setTimeout(() => {
          loader.classList.add('show');
        }, 10); // Small delay for smooth fade-in
      }
      // Optional: Prevent default and handle if needed, but for full page nav, let it proceed
    }
  });

  function highlightActiveMenu() {
    const path = window.location.pathname;
    const search = window.location.search;
    const url = path + search;

 
    document.querySelectorAll('.sidebar-menu a').forEach(a => a.classList.remove('active'));

   
    //const activeLink = document.querySelector(`.sidebar-menu a[href="${url}"]`) ||document.querySelector(`.sidebar-menu a[href^="${path}"]`);
    let activeLink = document.querySelector(`.sidebar-menu a[href="${url}"]`);
    if (!activeLink) {
      activeLink = document.querySelector(`.sidebar-menu a[href="${path}"]`);
    }
    if (activeLink) {
      activeLink.classList.add('active');
     
      const submenu = activeLink.closest('.submenu');
      if (submenu) {
        const button = submenu.previousElementSibling;
        if (button && button.classList.contains('menu-has-sub')) {
          button.setAttribute('aria-expanded', 'true');
          //submenu.style.display = 'flex';
          const section = button.closest('.menu-section');
          section.classList.add('open');

        }
      }
    }

    // === KHATABOOK TOGGLE LOGIC ===
    const khataMatch = url.match(/\/ledger\/trykhata\?type=(customer|supplier)/);
    if (khataMatch) {
      const type = khataMatch[1];
      localStorage.setItem('khataToggle', type);

      // Auto-click toggle in trykhata page
      setTimeout(() => {
        const toggleBtn = document.querySelector(`.toggle-btn[data-type="${type}"]`);
        if (toggleBtn) toggleBtn.click();
      }, 100);
    } else {
      // Restore from storage if on trykhata page
      if (path.includes('/ledger/trykhata') && localStorage.getItem('khataToggle')) {
        const type = localStorage.getItem('khataToggle');
        setTimeout(() => {
          const toggleBtn = document.querySelector(`.toggle-btn[data-type="${type}"]`);
          if (toggleBtn) toggleBtn.click();
        }, 100);
      }
    }
  }
</script>