<section class="business-scroller bg-white rounded-xl p-4 mb-6 shadow-md">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-800 flex items-center">
            <i class="fas fa-store mr-2 text-green-500"></i> Business Directory
        </h2>
        <div class="flex gap-2">
            <a href="/businesses/listUP"
                class="view-btn inline-flex items-center px-3 py-1 bg-green-600 text-white text-sm font-medium rounded-full hover:bg-green-700 transition-colors">
                <i class="fas fa-eye mr-1"></i> Browse All
            </a>
            {{#if showAddButton}}
            <a href="/businesses/new"
                class="action-btn inline-flex items-center px-3 py-1 bg-blue-600 text-white text-sm font-medium rounded-full hover:bg-blue-700 transition-colors">
                <i class="fas fa-plus mr-1"></i> List Business
            </a>
            {{/if}}
        </div>
    </div>
    <div class="scroller-wrapper">
        <div id="businessScroller" class="scroller flex overflow-x-auto space-x-4 pb-4 snap-x snap-mandatory">
            {{#each businesses}}
            <div class="business-scroll-card">
                <img src="{{profile_pic}}" alt="{{name}}" class="w-full h-40 object-cover rounded-t-lg">
                <div class="card-content">
                    <h3 class="font-bold text-base mb-2">{{name}}</h3>
                    <p class="description text-sm text-gray-600 mb-3">{{truncate description 60}}</p>
                    <p class="meta text-xs text-gray-500 mb-3">{{category}} • {{location}}</p>
                    <a href="/businesses/{{_id}}" class="view-link">View Details →</a>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</section>