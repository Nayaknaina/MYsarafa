<section class="business-scroller bg-white rounded-xl p-4 mb-6 shadow-md">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-800 flex items-center">
            <i class="fas fa-store mr-2 text-green-500"></i> Business Directory
        </h2>
        <div class="flex gap-2">
            <a href="/businesses/listUP"
                class="view-btn inline-flex items-center px-3 py-1 bg-green-600 text-white text-sm font-medium rounded-full hover:bg-green-700 transition-colors">
                <i class="fas fa-eye mr-1"></i> Browse All
            </a>
            {{#if showAddButton}}
            <a href="/businesses/listUP"
                class="action-btn inline-flex items-center px-3 py-1 bg-blue-600 text-white text-sm font-medium rounded-full hover:bg-blue-700 transition-colors">
                <i class="fas fa-plus mr-1"></i> List Business
            </a>
            {{/if}}
        </div>
    </div>
    <div class="scroller-wrapper">
        <div id="businessScroller" class="scroller  overflow-x-auto space-x-4 pb-4 snap-x snap-mandatory">
            {{#each businesses}}
            <div class="business-scroll-card">
                <div class="card-image-wrapper">
                    <img src="{{profile_pic}}" alt="{{name}}" class="w-full h-40 object-cover rounded-t-md">
                    <div class="business-initial-badge" data-name="{{name}}">
                    </div>
                </div>
                <div class="card-content">
                    <h3 class="font-bold text-base mb-2">{{name}}</h3>
                    <p class="description text-sm text-gray-600 mb-3">{{truncate description 60}}</p>
                    <p class="meta text-xs text-gray-500 mb-3">
                        <span class="category-pill">{{category}}</span>
                        <span class="location-text">
                            {{#if location}}
                            <span class="location-text">
                                <i class="fas fa-map-marker-alt"></i>
                                {{location}}
                            </span>
                            {{/if}}
                        </span>
                    </p>
                    <a href="/businesses/{{_id}}" class="view-link">
                        Visit Profile
                        <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</section>

<script>
    document.querySelectorAll('.business-initial-badge').forEach((badge) => {

    const name = badge.dataset.name?.trim() || '';

    if (!name) {
        badge.innerHTML = '<i class="fas fa-store"></i>';
        return;
    }

    // Split words and remove &, empty values
    const words = name
        .split(' ')
        .filter(word => word && word !== '&');

    let initials = '';

    if (words.length === 1) {
        initials = words[0][0];
    } else {
        initials = words[0][0] + words[1][0];
    }

    badge.textContent = initials.toUpperCase();
});
</script>