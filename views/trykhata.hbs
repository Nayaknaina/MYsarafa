  /* Main + Button - Add Transaction */
  #detailPanel > div > button[onclick="openAddModal()"] {
   bottom: 15% !important;
    right: 20px !important;
    width: 52px !important;
    height: 52px !important;
    background: #1976d2 !important;
    color: white !important;
    border-radius: 50% !important;
    font-size: 32px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    animation: pulse 2s infinite;
  }

  /* 3-Dot Menu Button */
  #actionMenuBtn {
    bottom: 10px !important; /* Above the + button */
    right: 24px !important;
    width: 52px !important;
    height: 52px !important;
    background: #1976d2 !important;
    color: white !important;
    border-radius: 50% !important;
    font-size: 22px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  /* Action Menu - slides up nicely */
  #actionButtons {
    position: fixed !important;
    /*bottom: 20% !important;*/
    right: 50% !important;
    left: auto !important;
    transform: translateX(50%) !important;
    width: 86% !important;
    max-width: 320px !important;
    background: white !important;
    border-radius: 16px !important;
    box-shadow: 0 15px 40px rgba(0,0,0,0.3) !important;
    padding: 16px !important;
    display: none !important;
    flex-direction: column !important;
    gap: 12px !important;
    z-index: 999 !important;
  }

  #actionButtons[style*="display: flex"],
  #actionButtons.show {
    display: flex !important;
  }

  /* Optional: subtle pulse animation for + button */
  @keyframes pulse {
    0% { box-shadow: 0 8px 25px rgba(25, 118, 210, 0.5); }
    50% { box-shadow: 0 12px 35px rgba(25, 118, 210, 0.7); }
    100% { box-shadow: 0 8px 25px rgba(25, 118, 210, 0.5); }
  }
