function calculateTotals(cust) {
  let cashIn = 0, cashOut = 0;
  let goldIn = 0, goldOut = 0;
  let silverIn = 0, silverOut = 0;

  (cust.entries || []).forEach(e => {
    const amt = Number(e.amount) || 0;
    if (e.item === 'cash') {
      if (e.transactionType === 'gave') cashOut += amt;   // you gave → OUT
      else cashIn += amt;                                 // you got → IN
    }
    else if (e.item === 'gold') {
      if (e.transactionType === 'gave') goldOut += amt;
      else goldIn += amt;
    }
    else if (e.item === 'silver') {
      if (e.transactionType === 'gave') silverOut += amt;
      else silverIn += amt;
    }
  });

  return {
    cashIn, cashOut, cashNet: cashIn - cashOut,
    goldIn, goldOut, goldNet: goldIn - goldOut,
    silverIn, silverOut, silverNet: silverIn - silverOut
  };
}
// CALCULATE TOTALS
function calculateCustomerTotals(cust) {
  let cashDr = cust.amount_balance || 0;
  let cashCr = 0;
  let goldDr = cust.gold_balance || 0;
  let goldCr = 0;
  let silverDr = cust.silver_balance || 0;
  let silverCr = 0;

  (cust.entries || []).forEach(e => {
    if (e.item === 'cash') {
      if (e.transactionType === 'gave') cashCr += e.amount;
      else cashDr += e.amount;
    } else if (e.item === 'gold') {
      if (e.transactionType === 'gave') goldCr += e.amount;
      else goldDr += e.amount;
    } else if (e.item === 'silver') {
      if (e.transactionType === 'gave') silverCr += e.amount;
      else silverDr += e.amount;
    }
  });

  return {
    cashDr, cashCr, goldDr, goldCr, silverDr, silverCr,
    cashNet: cashDr - cashCr,
    goldNet: goldDr - goldCr,
    silverNet: silverDr - silverCr
  };
}

