<script>
//let currentCash = 0, currentGold = 0, currentSilver = 0;
let isGave = true; 

function openAddModal() {
 if (!currentCustomerId) {
    toastr.warning("Please select a customer first!");
    return;
  }

  // CORRECTLY GET CUSTOMER NAME FROM BOTH MOBILE & DESKTOP
  const customerNameElement = document.getElementById('desktopName') || document.getElementById('mobileName');
  const customerName = customerNameElement ? customerNameElement.innerText.trim() : 'Customer';

  ;

  // Update modal header with customer name
  //document.getElementById('currentCustomerName').innerText = customerName;
  currentCash = parseFloat(document.getElementById('cashBal').innerText.replace(/[^\d.-]/g, '')) || 0;
  currentGold = parseFloat(document.getElementById('goldBal').innerText.replace(/[^\d.-]/g, '')) || 0;
  currentSilver = parseFloat(document.getElementById('silverBal').innerText.replace(/[^\d.-]/g, '')) || 0;

  // Reset only display value, keep data attributes
  document.getElementById('amtCash').value = '';
  document.getElementById('amtGold').value = '';
  document.getElementById('amtSilver').value = '';

  // Reset data attributes
  ['amtCash', 'amtGold', 'amtSilver'].forEach(id => {
    document.getElementById(id).dataset.gave = '0';
    document.getElementById(id).dataset.got = '0';
  });

  isGave = true;
  ;
  document.getElementById('btnGave').classList.add('active');
  document.getElementById('btnGot').classList.remove('active');

  updatePreviewAndFinal();
  document.getElementById('addTransactionModal').style.display = 'flex';
}

function closeAddModal() {
  document.getElementById('addTransactionModal').style.display = 'none';
}


document.getElementById('btnGave').onclick = () => {
  isGave = true;
  document.getElementById('btnGave').classList.add('active');
  document.getElementById('btnGot').classList.remove('active');
  updatePreviewAndFinal();
};

document.getElementById('btnGot').onclick = () => {
  isGave = false;
  document.getElementById('btnGot').classList.add('active');
  document.getElementById('btnGave').classList.remove('active');
  updatePreviewAndFinal();
};


['amtCash', 'amtGold', 'amtSilver'].forEach(id => {
  const input = document.getElementById(id);
  input.addEventListener('input', () => {
    const val = input.value || '0';
    if (isGave) {
      input.dataset.gave = val;
    } else {
      input.dataset.got = val;
    }
    updatePreviewAndFinal();
  });
});

function updatePreviewAndFinal() {
  const gaveCash = parseFloat(document.getElementById('amtCash').dataset.gave) || 0;
  const gaveGold = parseFloat(document.getElementById('amtGold').dataset.gave) || 0;
  const gaveSilver = parseFloat(document.getElementById('amtSilver').dataset.gave) || 0;

  const gotCash = parseFloat(document.getElementById('amtCash').dataset.got) || 0;
  const gotGold = parseFloat(document.getElementById('amtGold').dataset.got) || 0;
  const gotSilver = parseFloat(document.getElementById('amtSilver').dataset.got) || 0;

  // Show only current toggle values in input
  document.getElementById('amtCash').value = isGave ? gaveCash || '' : gotCash || '';
  document.getElementById('amtGold').value = isGave ? gaveGold || '' : gotGold || '';
  document.getElementById('amtSilver').value = isGave ? gaveSilver || '' : gotSilver || '';

  const sign = isGave ? '−' : '+';
  const cls = isGave ? 'gave' : 'got';

  // Preview only current toggle
  document.getElementById('previewCash').textContent   = (isGave ? gaveCash : gotCash) > 0 ? `${sign}₹${(isGave ? gaveCash : gotCash).toLocaleString()}` : '—';
  document.getElementById('previewGold').textContent   = (isGave ? gaveGold : gotGold) > 0 ? `${sign}${(isGave ? gaveGold : gotGold).toFixed(2)}g` : '—';
  document.getElementById('previewSilver').textContent = (isGave ? gaveSilver : gotSilver) > 0 ? `${sign}${(isGave ? gaveSilver : gotSilver).toFixed(2)}g` : '—';

  ['previewCash', 'previewGold', 'previewSilver'].forEach(el => {
    const elem = document.getElementById(el);
    elem.className = 'preview';
    if (elem.textContent !== '—') elem.classList.add(cls);
  });

  // FINAL BALANCE = current + all got - all gave
  const finalCash = currentCash - gaveCash + gotCash;
  const finalGold = currentGold - gaveGold + gotGold;
  const finalSilver = currentSilver - gaveSilver + gotSilver;

  document.getElementById('finalCash').textContent = finalCash.toLocaleString();
  document.getElementById('finalGold').textContent = finalGold.toFixed(2);
  document.getElementById('finalSilver').textContent = finalSilver.toFixed(2);
}

async function saveAllEntries() {
  const gaveCash = parseFloat(document.getElementById('amtCash').dataset.gave) || 0;
  const gaveGold = parseFloat(document.getElementById('amtGold').dataset.gave) || 0;
  const gaveSilver = parseFloat(document.getElementById('amtSilver').dataset.gave) || 0;

  const gotCash = parseFloat(document.getElementById('amtCash').dataset.got) || 0;
  const gotGold = parseFloat(document.getElementById('amtGold').dataset.got) || 0;
  const gotSilver = parseFloat(document.getElementById('amtSilver').dataset.got) || 0;

  const total = gaveCash + gaveGold + gaveSilver + gotCash + gotGold + gotSilver;
  if (total === 0) {
    toastr.error("Enter at least one amount");
    return;
  }

  const entries = [];
  if (gaveCash > 0)   entries.push({ type: 'cash',   amount: gaveCash,   transactionType: 'gave' });
  if (gaveGold > 0)   entries.push({ type: 'gold',   amount: gaveGold,   transactionType: 'gave' });
  if (gaveSilver > 0) entries.push({ type: 'silver', amount: gaveSilver, transactionType: 'gave' });
  if (gotCash >  0) entries.push({ type: 'cash',   amount: gotCash,    transactionType: 'got' });
  if (gotGold  > 0)   entries.push({ type: 'gold',   amount: gotGold,    transactionType: 'got' });
  if (gotSilver > 0)  entries.push({ type: 'silver', amount: gotSilver,  transactionType: 'got' });

  let successCount = 0;

  try {
    for (let e of entries) {
      const res = await fetch('/ledger/transaction/new', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customerId: currentCustomerId, ...e })
      });

      // THIS IS THE KEY: Check if response is actually OK
      if (!res.ok) {
        const errorData = await res.json().catch(() => ({}));
        throw new Error(errorData.message || `Server error: ${res.status}`);
      }

      const data = await res.json();
      if (!data.success) {
        throw new Error(data.message || "Transaction failed");
      }

      successCount++;
    }

    // Only refresh if at least one succeeded
    await fetchCustomer(currentCustomerId);

    toastr.success(`${successCount} entries saved successfully!`);
    closeAddModal();

  } catch (err) {
    console.error("Save error:", err);
    toastr.error(err.message || "Save failed");
  }
}
</script>
