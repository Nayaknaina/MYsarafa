          method: 'POST',
          body: formData
        });

        const result = await res.json();

        if (res.ok) {
          document.getElementById('uploadStatus').innerHTML = `<span style="color:green;">Success! ${result.added} customers added</span>`;
          toastr.success(`${result.added} customers uploaded successfully!`);

          // ADD NEW CUSTOMERS TO LIST INSTANTLY
          result.customers.forEach(cust => {
            allCustomers.unshift(cust);
            if (cust.type === 'customer') {
              document.getElementById('customerCount').innerText = parseInt(document.getElementById('customerCount').innerText) + 1;
            } else {
              document.getElementById('supplierCount').innerText = parseInt(document.getElementById('supplierCount').innerText) + 1;
