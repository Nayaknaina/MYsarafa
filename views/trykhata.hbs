function generateSinglePDF(cust, includeEntries) {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF('p', 'mm', 'a4');

  // Header
  doc.setFillColor(26,43,77);
  doc.rect(0,0,210,35,'F');
  doc.setTextColor(255,255,255);
  doc.setFontSize(20);
  doc.text('KhataBook',105,25,{align:'center'});
  doc.setTextColor(0);
  doc.setFontSize(16);
  doc.text(cust.name,105,45,{align:'center'});
  doc.setFontSize(10);
  doc.text(`Generated: ${generatedTime}`,105,52,{align:'center'});

  const head = [['Date','Details',
                 'Cash Out','Cash In',
                 'Gold Out','Gold In',
                 'Silver Out','Silver In']];
  const body = [];

  // ---- Opening Balance ----
  const open = ['Opening Balance','',
    cust.amount_balance<0?`- ${Math.abs(cust.amount_balance)}`:'',
    cust.amount_balance>0?`+ ${cust.amount_balance}`:'',
    cust.gold_balance<0?`- ${Math.abs(cust.gold_balance)}g`:'',
    cust.gold_balance>0?`+ ${cust.gold_balance}g`:'',
    cust.silver_balance<0?`- ${Math.abs(cust.silver_balance)}g`:'',
    cust.silver_balance>0?`+ ${cust.silver_balance}g`:'' ];
  body.push(open);

  // ---- ALL Entries (date-time wise) ----
  if (includeEntries && cust.entries && cust.entries.length) {
    const sorted = [...cust.entries].sort((a,b)=>new Date(a.date)-new Date(b.date));
    sorted.forEach(e => {
      const dt = new Date(e.date).toLocaleString('en-IN',{dateStyle:'short',timeStyle:'short'});
      const isOut = e.transactionType === 'gave';
      const sign = isOut ? '-' : '+';
      const row = [dt, isOut?'You Gave':'You Got'];

      // cash
      row.push(e.item==='cash' && isOut ? `${sign} ${e.amount}` : '');
      row.push(e.item==='cash' && !isOut? `${sign} ${e.amount}` : '');

      // gold
      row.push(e.item==='gold' && isOut ? `${sign} ${e.amount}g` : '');
      row.push(e.item==='gold' && !isOut? `${sign} ${e.amount}g` : '');

      // silver
      row.push(e.item==='silver' && isOut ? `${sign} ${e.amount}g` : '');
      row.push(e.item==='silver' && !isOut? `${sign} ${e.amount}g` : '');

      body.push(row);
    });
  }

  // ---- Totals ----
  const tot = calculateTotals(cust);
  const totRow = ['Total','',
    tot.cashOut ? `- ${tot.cashOut}` : '',
    tot.cashIn  ? `+ ${tot.cashIn}`  : '',
    tot.goldOut ? `- ${tot.goldOut}g` : '',
    tot.goldIn  ? `+ ${tot.goldIn}g`  : '',
    tot.silverOut? `- ${tot.silverOut}g` : '',
    tot.silverIn ? `+ ${tot.silverIn}g`  : ''];
  body.push(totRow);

  // ---- Net Balance ----
  const netRow = ['Net Balance','',
    tot.cashNet !== 0 ? `${tot.cashNet>0?'+':'-'} ${Math.abs(tot.cashNet)}` : '0',
    '',
    tot.goldNet !== 0 ? `${tot.goldNet>0?'+':'-'} ${Math.abs(tot.goldNet)}g` : '0g',
    '',
    tot.silverNet !== 0 ? `${tot.silverNet>0?'+':'-'} ${Math.abs(tot.silverNet)}g` : '0g',
    ''];
  body.push(netRow);

  doc.autoTable({
    startY:60,
    head, body,
    theme:'grid',
    styles:{fontSize:9,cellPadding:2.5,halign:'center'},
    headStyles:{fillColor:[26,43,77], textColor: [255,255,255], fontStyle: 'bold'},
    columnStyles:{
      0:{cellWidth:28},1:{cellWidth:30},
      2:{cellWidth:22},3:{cellWidth:22},
      4:{cellWidth:22},5:{cellWidth:22},
      6:{cellWidth:22},7:{cellWidth:22}
    },
    didParseCell:data=>{
      const txt = data.cell.text[0]||'';
      if (txt.startsWith('-')) data.cell.styles.textColor = [200,0,0]; 
      if (txt.startsWith('+')) data.cell.styles.textColor = [0,120,0]; 

      if (data.row.raw[0]==='Opening Balance') data.cell.styles.fillColor=[255,240,230];
      if (data.row.raw[0]==='Total')           data.cell.styles.fillColor=[230,255,230];
      if (data.row.raw[0]==='Net Balance')     data.cell.styles.fillColor=[245,245,255];
    }
  });

  // Grand total bar
  const y = doc.lastAutoTable.finalY + 10;
  doc.setFillColor(26,43,77);
  doc.rect(10,y,190,15,'F');
  doc.setTextColor(255,255,255);
  doc.setFontSize(14);
  doc.text('NET BALANCE',20,y+10);

  doc.setTextColor(200,0,0);
  doc.text(`CASH: ${tot.cashNet>0?'+':(tot.cashNet<0?'-':'')} ${Math.abs(tot.cashNet)}`,70,y+10);
  doc.setTextColor(0,120,0);
  doc.text(`GOLD: ${tot.goldNet>0?'+':(tot.goldNet<0?'-':'')} ${Math.abs(tot.goldNet)}g`,120,y+10);
  doc.setTextColor(0,120,0);
  doc.text(`SILVER: ${tot.silverNet>0?'+':(tot.silverNet<0?'-':'')} ${Math.abs(tot.silverNet)}g`,160,y+10);
  const fileName = `${cust.name}_Report.pdf`;
  doc.setProperties({
    title: `${cust.name}_Report`
  });
 
  // doc.save(`${cust.name}_Report.pdf`);
  const pdfBlob = doc.output('blob');
  const pdfFile = new File([pdfBlob], fileName, { type: "application/pdf" });
  const pdfURL = URL.createObjectURL(pdfFile);
 

  window.open(pdfURL, '_blank');
}

