        e.item === 'cash' && e.transactionType === 'got' ? e.amount : "",
        e.item === 'gold' && e.transactionType === 'gave' ? e.amount : "",
        e.item === 'gold' && e.transactionType === 'got' ? e.amount : "",
        e.item === 'silver' && e.transactionType === 'gave' ? e.amount : "",
        e.item === 'silver' && e.transactionType === 'got' ? e.amount : ""
      ]);
    });
  }

  const tot = calculateCustomerTotals(cust);
  data.push([generatedTime, "Total", "", tot.cashDr, tot.cashCr, tot.goldDr, tot.goldCr, tot.silverDr, tot.silverCr]);
