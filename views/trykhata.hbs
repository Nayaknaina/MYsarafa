    )
    .slice(0, 10); // sirf 10 dikhao

  if (matched.length === 0) {
    dropdown.innerHTML = '<div class="dropdown-item" style="color:#999; text-align:center;">No customer found</div>';
    dropdown.style.display = 'block';
    return;
  }

  dropdown.innerHTML = matched.map(c => `
    <div class="dropdown-item" onclick="loadCustomer('${c._id}', '${c.name}', '${c.mobile_no}')">
      <strong>${c.name}</strong><br>
      <small style="color:#666;">${c.mobile_no}</small>
      ${c.amount_balance !== 0 || c.gold_balance !== 0 || c.silver_balance !== 0 
