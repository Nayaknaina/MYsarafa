  <script src="/js/all.js"></script>
  <script>
    let currentCustomerId = null;
    let selectedType = 'cash';
    let transactionType = 'gave';
    let currentFilterType = 'customer';
    let allCustomers = {{{ json customers }}};

    const customerCount = allCustomers.filter(c => c.type === 'customer').length;
    const supplierCount = allCustomers.filter(c => c.type === 'supplier').length;
    document.getElementById('customerCount').innerText = customerCount; 
    document.getElementById('supplierCount').innerText = supplierCount;

    const urlParams = new URLSearchParams(window.location.search);
    const urlType = urlParams.get('type');
    const storedType = localStorage.getItem('khataToggle');
    currentFilterType = urlType || storedType || 'customer';

    
    document.querySelectorAll('.toggle-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.type === currentFilterType);
    });

    localStorage.setItem('khataToggle', currentFilterType);

    function formatBalance(value, type = 'cash') {
      if (!value) value = 0;
      const abs = Math.abs(value);
      const sign = value > 0 ? '+' : value < 0 ? '−' : '';
      const color = value > 0 ? '#2e7d32' : value < 0 ? '#c62828' : '#666';
      const formatted = type === 'cash' ? abs.toLocaleString() : abs.toFixed(2);

      if (type === 'cash') {

        return `<span style="color:${color};font-weight:bold;">${sign}₹${formatted}</span>`;
      } else {

        return `<span style="color:${color};font-weight:bold;">${sign}${formatted}g</span>`;
      }
    }
   
    function showReportButton() {
      document.getElementById('viewReportBtn').style.display = 'block';
    }

    function renderCustomerList() {
      const list = document.getElementById('customerList');
      const searchTerm = document.querySelector('.search-box input').value.toLowerCase().trim();
      
      const filterValue = document.querySelector('.filter-select').value; // gold, silver, cash
      const sortValue = document.querySelector('.sort-select').value;
      list.innerHTML = '';
      
     /* let filtered = allCustomers.filter(c => {
        if (c.type !== currentFilterType) return false;
        const isSearching = searchTerm.length > 0;

        const hasBalance = c.amount_balance !== 0 || c.gold_balance !== 0 || c.silver_balance !== 0;
        if (!isSearching) {
        
          if (!hasBalance) return false;
        }

        const matches =  c.name.toLowerCase().includes(searchTerm) || (c.mobile_no && c.mobile_no.toString().includes(searchTerm));
        return hasBalance || matches;
      });
      console.log("filmtered",filtered)
  
      filtered.sort((a, b) => new Date(b.createdAt || 0) - new Date(a.createdAt || 0));

      if (filtered.length === 0) {
        list.innerHTML = `<div style="padding:20px; text-align:center; color:#999;">
            No ${currentFilterType}s with balance yet<br>
            <small style="color:#1976d2;">Start adding transactions to see them here</small>
          </div>`;
        return;
      }*/
      let filtered = allCustomers.filter(c => {
        // 1. Match current tab (customer/supplier)
        if (c.type !== currentFilterType) return false;

        const isSearching = searchTerm.length > 0;
        const hasBalance = c.amount_balance !== 0 || c.gold_balance !== 0 || c.silver_balance !== 0;
        if (!isSearching) {
        
          if (!hasBalance) return false;
        }

        // 2. Search by name or mobile
        const matchesSearch = !searchTerm || 
          c.name.toLowerCase().includes(searchTerm) || 
          (c.mobile_no && c.mobile_no.includes(searchTerm));

        // 3. Filter by balance type (gold/silver/cash)
        if (filterValue === 'gold' && c.gold_balance === 0) return false;
        if (filterValue === 'silver' && c.silver_balance === 0) return false;
        if (filterValue === 'cash' && c.amount_balance === 0) return false;

        return hasBalance||matchesSearch;
       });

      // SORTING
      if (sortValue === 'recent') {
        filtered.sort((a, b) => new Date(b.createdAt || b.updatedAt || 0) - new Date(a.createdAt || a.updatedAt || 0));
      } else if (sortValue === 'name') {
        filtered.sort((a, b) => a.name.localeCompare(b.name));
      }

  // EMPTY STATE
  if (filtered.length === 0) {
    let message = '';
    if (allCustomers.filter(c => c.type === currentFilterType).length === 0) {
      message = `
        <div style="padding:40px 20px; text-align:center; color:#999;">
          <div >No customers yet</div>
          <p style="font-size:16px; margin:10px 0;">Start by adding your first ${currentFilterType}</p>
          <button class="action-btn" onclick="document.getElementById('btn-new-customer').click()" style="display:inline-block !important;">
            Add First ${currentFilterType.charAt(0).toUpperCase() + currentFilterType.slice(1)}
          </button>
        </div>`;
    } else if (filterValue) {
      const labels = { cash: 'Cash', gold: 'Gold', silver: 'Silver' };
      message = `<div style="text-align:center; padding:40px; color:#888;">
        No ${currentFilterType}s with <strong>${labels[filterValue]}</strong> balance
        <br><small style="color:#1976d2; margin-top:8px; display:block;">Try changing filter</small>
      </div>`;
    } else {
      message = `<div style="text-align:center; padding:40px; color:#888;">
        No ${currentFilterType}s with balance yet<br>
        <small style="color:#1976d2;">Start search and adding transactions to see them here</small>
      </div>`;
    }
    list.innerHTML = message;
    return;
  }

      //RENDER CUSTOMERS
      filtered.forEach(c => {
        const div = document.createElement('div');
        div.className = 'customer-item';
        div.onclick = () => loadCustomer(c._id);

        const miniCash = formatBalance(c.amount_balance, 'cash');
        const miniGold = formatBalance(c.gold_balance, 'gold');
        const miniSilver = formatBalance(c.silver_balance, 'silver');

        div.innerHTML = `
        <div class="avatar">${getInitials(c.name)}</div>
        <div style="flex:1; min-width:0;">
          <div class="customer-name" style="font-weight:600; margin-bottom:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            ${c.name}
          </div>
          <div style="display:flex; gap:8px; font-size:11px; color:#555; flex-wrap:wrap;">

            <!-- cash COIN ICON -->
            <span style="display:flex; align-items:center; gap:5px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="4" y="6" width="16" height="12" rx="2" fill="#4caf50"/>
              <rect x="6" y="8" width="12" height="8" fill="#81c784"/>
              <path d="M8 12h8M8 14h8" stroke="#2e7d32" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="2" fill="#2e7d32"/>
              <path d="M12 10v4" stroke="#fff" stroke-width="1.5"/>
            </svg>
            <span style="color:#2e7d32;">${miniCash}</span>
            </span>

            <!-- GOLD COIN ICON -->
            <span style="display:flex; align-items:center; gap:5px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="9" fill="#fdd835" stroke="#f9a825" stroke-width="2"/>
              <circle cx="12" cy="12" r="6" fill="#ffb300"/>
              <text x="12" y="15" text-anchor="middle" font-size="10" fill="#c68400" font-weight="bold">G</text>
            </svg>
            <span style="color:#f9a825;">${miniGold}</span>
            </span>

            <!-- SILVER COIN ICON -->
            <span style="display:flex; align-items:center; gap:5px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="9" fill="#e0e0e0" stroke="#9e9e9e" stroke-width="2"/>
              <circle cx="12" cy="12" r="6" fill="#eeeeee"/>
              <text x="12" y="15" text-anchor="middle" font-size="10" fill="#616161" font-weight="bold">S</text>
            </svg>
            <span style="color:#546e7a;">${miniSilver}</span>
            </span>
          </div>
        </div>
        `;
          list.appendChild(div);
      });
    }

   
    document.querySelector('.search-box input').addEventListener('input', renderCustomerList);
    document.querySelector('.filter-select').addEventListener('change', renderCustomerList);
    document.querySelector('.sort-select').addEventListener('change', renderCustomerList);

    document.querySelectorAll('.user-toggle-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.user-toggle-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentFilterType = btn.dataset.type;
        renderCustomerList();
      });
    });


    renderCustomerList();

    function updateLayout() {
      const isMobile = window.innerWidth <= 767;
      console.log("isit mobile view",isMobile);
      //console.log("here",isMobile)
      document.getElementById('mobileHeader').style.display = isMobile ? 'flex' : 'none';
      document.getElementById('desktopHeader').style.display = isMobile ? 'none' : 'flex';
      document.getElementById('noCustomerState').style.display = isMobile ? 'none' : (currentCustomerId ? 'none' : 'flex');
      document.body.classList.toggle('mobile-open', isMobile && currentCustomerId);
      // After page load
      document.getElementById('totalCashBal').innerHTML = formatBalance({{{ totalCash }}}, 'cash');
      document.getElementById('totalGoldBal').innerHTML = formatBalance({{{ totalGold }}}, 'gold');
      document.getElementById('totalSilverBal').innerHTML = formatBalance({{{ totalSilver }}}, 'silver');
    }

    function loadCustomer(id) {
      currentCustomerId = id;
      const detailPanel = document.getElementById('detailPanel');
      if (window.innerWidth <= 767) {
        document.body.classList.add('mobile-open');
      } else {
