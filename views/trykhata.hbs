/* ---------- FULL PDF – ONLY THIS FUNCTION CHANGES ---------- */
function generateFullPDF(includeEntries) {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF('p', 'mm', 'a4');
  let yPos = 20;

  // Global header (once)
  doc.setFillColor(26,43,77);
  doc.rect(0,0,210,35,'F');
  doc.setTextColor(255,255,255);
  doc.setFontSize(20);
  doc.text('KhataBook',105,25,{align:'center'});
  doc.setTextColor(0);
  doc.setFontSize(16);
  doc.text('Full Business Report',105,45,{align:'center'});
  doc.setFontSize(10);
  doc.text(`Generated: ${generatedTime}`,105,52,{align:'center'});

  // *** NEW HEADER YOU ASKED FOR ***
  const head = [['S.No','Name','Mobile No','Cash','Gold','Silver']];
  const body = [];

  let grandCash = 0, grandGold = 0, grandSilver = 0;

  allReportData.forEach((cust, idx) => {
    const tot = calculateTotals(cust);
    grandCash   += tot.cashNet;
    grandGold   += tot.goldNet;
    grandSilver += tot.silverNet;

    // ---- One row per customer (summary) ----
    const signC = tot.cashNet   > 0 ? '+' : (tot.cashNet   < 0 ? '-' : '');
    const signG = tot.goldNet   > 0 ? '+' : (tot.goldNet   < 0 ? '-' : '');
    const signS = tot.silverNet > 0 ? '+' : (tot.silverNet < 0 ? '-' : '');

    body.push([
      `${idx+1}`,                                           // S.No
      cust.name,                                            // Name
      cust.mobile || '',                                    // Mobile No
      `${signC}${Math.abs(tot.cashNet)}`,                   // Cash
      `${signG}${Math.abs(tot.goldNet)}g`,                  // Gold
      `${signS}${Math.abs(tot.silverNet)}g`                 // Silver
    ]);

    // ---- OPTIONAL: detailed entries per customer (same as before) ----
    if (includeEntries && cust.entries?.length) {
      // add a blank line before details
      body.push(['','','','','','']);

      const sorted = [...cust.entries].sort((a,b)=>new Date(a.date)-new Date(b.date));
      sorted.forEach(e => {
        const dt = new Date(e.date).toLocaleString('en-IN',{dateStyle:'short',timeStyle:'short'});
        const isOut = e.transactionType === 'gave';
        const sign = isOut ? '-' : '+';
        const row = [dt, isOut ? 'You Gave' : 'You Got'];
        row.push(e.item==='cash'   && isOut ? `${sign} ${e.amount}` : '');
        row.push(e.item==='cash'   && !isOut? `${sign} ${e.amount}` : '');
        row.push(e.item==='gold'   && isOut ? `${sign} ${e.amount}g` : '');
        row.push(e.item==='gold'   && !isOut? `${sign} ${e.amount}g` : '');
        row.push(e.item==='silver' && isOut ? `${sign} ${e.amount}g` : '');
        row.push(e.item==='silver' && !isOut? `${sign} ${e.amount}g` : '');
        body.push(row);
      });
    }
  });

  // ---- Draw the table (summary + optional details) ----
  doc.autoTable({
    startY: 60,
    head, body,
    theme: 'grid',
    styles: {fontSize:8, cellPadding:2.5, halign:'center'},
    headStyles: {fillColor:[26,43,77], textColor:[255,255,255], fontStyle:'bold'},
    columnStyles: {
      0:{cellWidth:15},1:{cellWidth:45},2:{cellWidth:30},
      3:{cellWidth:25},4:{cellWidth:25},5:{cellWidth:30}
    },
    margin:{left:10,right:10},
    didParseCell: data => {
      // colour + / - for Cash / Gold / Silver columns
      if (data.column.index >= 3) {
        const txt = data.cell.text[0] || '';
        if (txt.startsWith('-')) data.cell.styles.textColor = [200,0,0];   // red
        if (txt.startsWith('+')) data.cell.styles.textColor = [0,120,0];  // green
      }
    }
  });

  // ---- GRAND TOTAL PAGE ----
  const finalY = doc.lastAutoTable.finalY + 15;
  if (finalY > 250) { doc.addPage(); }

  doc.setFillColor(26,43,77);
  doc.rect(0,0,210,35,'F');
  doc.setTextColor(255,255,255);
  doc.setFontSize(18);
  doc.text('GRAND TOTAL',105,25,{align:'center'});

  let gy = 50;
  doc.setFontSize(16);
  doc.setTextColor(grandCash<0?[200,0,0]:[0,120,0]);
  doc.text(`CASH: ${grandCash>0?'+':(grandCash<0?'-':'')} ${Math.abs(grandCash)}`,20,gy);
  doc.setTextColor(grandGold<0?[200,0,0]:[0,120,0]);
  doc.text(`GOLD: ${grandGold>0?'+':(grandGold<0?'-':'')} ${Math.abs(grandGold)}g`,20,gy+=20);
  doc.setTextColor(grandSilver<0?[200,0,0]:[0,120,0]);
  doc.text(`SILVER: ${grandSilver>0?'+':(grandSilver<0?'-':'')} ${Math.abs(grandSilver)}g`,20,gy+=20);

  doc.save('Mysarafa_Full_Report.pdf');
}


