// ==== AUTOCOMPLETE SEARCH ====
const searchInputbox = document.getElementById('customerSearchInput');
const autocompleteList = document.getElementById('autocompleteList');

searchInputbox.addEventListener('input', function () {
  const term = this.value.trim().toLowerCase();
  autocompleteList.innerHTML = '';

  if (term === '') {
    autocompleteList.style.display = 'none';
    renderCustomerList(); // fallback to normal list
    return;
  }

  const matches = allCustomers
    .filter(c => c.type === currentFilterType)
    .filter(c => 
      c.name.toLowerCase().includes(term) || 
      (c.mobile_no && c.mobile_no.includes(term))
    )
    .slice(0, 8); // limit suggestions

  if (matches.length === 0) {
    autocompleteList.innerHTML = '<div style="padding:12px;color:#999;">No customer found</div>';
    autocompleteList.style.display = 'block';
    return;
  }

  matches.forEach(c => {
    const item = document.createElement('div');
    item.style.padding = '12px 16px';
    item.style.cursor = 'pointer';
    item.style.borderBottom = '1px solid #eee';
    item.innerHTML = `
      <div style="font-weight:600;">${c.name}</div>
      ${c.mobile_no ? `<div style="font-size:12px;color:#666;">${c.mobile_no}</div>` : ''}
    `;
    item.onclick = (e) => {
      e.stopPropagation();
      loadCustomer(c._id);
      searchInputbox.value = c.name;
      autocompleteList.style.display = 'none';
    };
    item.onmouseover = () => item.style.backgroundColor = '#f0f0f0';
    item.onmouseout = () => item.style.backgroundColor = 'white';
    autocompleteList.appendChild(item);
  });

  autocompleteList.style.display = 'block';
});


// Hide dropdown when clicking outside
document.addEventListener('click', (e) => {
  
if (!searchInputbox || !autocompleteList) return;
  if (!searchInputbox.contains(e.target) && !autocompleteList.contains(e.target)) {
    autocompleteList.style.display = 'none';
  }
});

// Optional: keep normal list filtering as fallback
searchInputbox.addEventListener('input', () => {
  if (searchInputbox.value.trim() === '') {
    renderCustomerList();
  }
});
