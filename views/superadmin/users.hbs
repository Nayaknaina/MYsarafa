    <div class="page-container">
        <!-- HEADER DESKTOP-->
        {{> superdesktopheader}}
        <div class="main-content">
            <div class="section__content section__content--p30">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="overview-wrap">
                                <h2 class="title-1">overview</h2>
                                <button class="au-btn au-btn-icon au-btn--blue">
                                    <i class="zmdi zmdi-plus"></i>Create New User</button>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <h2 class="title-1 m-b-25">Users</h2>
                            <div class="table-responsive table--no-card m-b-40">
                                <table id="usersTable" class="table table-borderless table-striped table-earning">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Roles</th>
                                            <th>KYC Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {{#each user}}
                                          <tr class="{{#if blacklistStatus}}blacklisted{{/if}}">
                                            <td>{{f_name}} {{l_name}}     
                                                {{#if blacklistStatus}}
                                            <span class="badge bg-danger ms-2" title="Blacklisted">Blacklisted</span>
                                            {{/if}}
                                           </td>
                                            <td>{{email}}</td>
                                            <td>{{role}}</td>
                                            <td>{{kyc_status}}</td>
                                            <td>
                                                <button class="btn btn-sm btn-primary edit-btn"
                                                    data-id="{{_id}}">Edit</button>
                                                <button class="btn btn-sm btn-danger delete-btn"
                                                    data-id="{{_id}}">Delete</button>
                                                <button class="btn btn-sm btn-info view-btn" data-id="{{_id}}"
                                                    title="View Details"><i class="fas fa-eye"></i></button>

                                            </td>
                                        </tr>
                                        {{/each}}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        {{!-- <div class="col-lg-3">
                            <h2 class="title-1 m-b-25">Roles</h2>
                            <div class="au-card au-card--bg-blue au-card-top-countries m-b-40">
                                <div class="au-card-inner">
                                    <div class="table-responsive">
                                        <table id="rolesTable" class="table table-top-countries">
                                            <tbody>
                                                {{#each user}}
