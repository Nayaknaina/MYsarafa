                        </div> --}}
                    </div>
                </div>
            </div>
            <div class="modal fade" id="createModal" tabindex="-1" data-bs-backdrop="static">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Create New User</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <form id="createForm" autocomplete="on">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">First Name</label>
                                        <input type="text" class="form-control" name="f_name" required
                                            autocomplete="given-name">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Last Name</label>
                                        <input type="text" class="form-control" name="l_name" required
                                            autocomplete="family-name">
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Email</label>
                                        <input type="email" class="form-control" name="email" required
                                            autocomplete="email">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Mobile No</label>
                                        <input type="text" class="form-control" name="mobile_no" required
                                            autocomplete="tel">
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Password</label>
                                        <input type="password" class="form-control" name="password" required
                                            minlength="6" autocomplete="new-password">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Role *</label>
                                        <select class="form-control" name="role" required>
                                            <option value="">Select Role</option>
                                            {{#each roleOptions}}
                                            <option value="{{this}}">{{this}}</option>
                                            {{/each}}
                                        </select>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">KYC Status</label>
                                        <select class="form-control" name="kyc_status" autocomplete="off">
                                            <option value="">Select Status</option>
                                            {{#each kycOptions}}
                                            <option value="{{this}}">{{this}}</option>
                                            {{/each}}
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Country</label>
                                        <input type="text" class="form-control" name="country"
                                            autocomplete="country-name">
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Category *</label>
                                        <select class="form-control" name="category" required autocomplete="off">
                                            <option value="">Select Category</option>
                                            {{#each categoryOptions}}
                                            <option value="{{this}}">{{this}}</option>
                                            {{/each}}
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Shop Name</label>
                                        <input type="text" class="form-control" name="shopname"
                                            autocomplete="organization">
                                    </div>
                                </div>
                            </form>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="button" class="btn btn-primary" id="saveCreate">Create User</button>
                        </div>
                    </div>
                </div>
            </div>

      
            <div class="modal fade" id="viewModal" tabindex="-1">
                <div class="modal-dialog modal-xl">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">User Details</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body" id="userDetailsBody">
                            <!-- Populated via JS -->
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal fade" id="editModal" tabindex="-1" data-bs-backdrop="static">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Edit User</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <form id="editForm">
                                <input type="hidden" id="editUserId" name="_id">
                                <!-- Existing fields (f_name, l_name, email, role, kyc_status) unchanged -->
                                <div class="mb-3">
                                    <label class="form-label">First Name</label>
                                    <input type="text" class="form-control" name="f_name" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Last Name</label>
                                    <input type="text" class="form-control" name="l_name" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Email</label>
                                    <input type="email" class="form-control" name="email" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Role</label>
                                    <select class="form-control" name="role">
                                        {{#each roleOptions}}
                                        <option value="{{this}}">{{this}}</option>
                                        {{/each}}
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">KYC Status</label>
                                    <select class="form-control" name="kyc_status">
                                        {{#each kycOptions}}
                                        <option value="{{this}}">{{this}}</option>
                                        {{/each}}
                                    </select>
                                </div>
                                <div class="mb-3"> 
                                    <label class="form-label">Blacklist Status</label> 
                                    <div class="form-check"> 
                                        <input class="form-check-input" type="checkbox" name="blacklistStatus" id="blacklistStatus"> <label class="form-check-label" for="blacklistStatus">Blacklisted?</label>
                                     </div> 
                                </div>
                                <!-- NEW: Blacklist Fields -->
                                <div class="mb-3" id="blacklistReasonBox" style="display: none;">
                                    <label for="blacklistReason" class="form-label">Blacklist Reason</label>
                                    <textarea class="form-control" name="blacklistReason" id="blacklistReason" rows="3"></textarea>
                                </div>

                             
                            </form>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                            <button type="button" class="btn btn-primary" id="saveEdit">Save Changes</button>
                        </div>
                    </div>
                </div>
            </div>



            <script src="https://code.jquery.com/jquery-3.7.1.js"></script>

            <!-- DataTables JS -->

            <script src="https://cdn.datatables.net/2.3.4/js/dataTables.js"></script>
            <script src="https://cdn.datatables.net/2.3.4/js/dataTables.bootstrap5.js"></script>


            <script>
                const jq = jQuery.noConflict(false);

                jq(document).ready(function () {
                    console.log(1);

                    // Initialize DataTable
                    jq('#usersTable').DataTable();

                    // Create Modal open
                    jq('.au-btn--blue').on('click', function (e) {
                        e.preventDefault();
                        jq('#createForm')[0].reset();
                        jq('#createModal').modal('show');
                    });

                    // Create (AJAX POST)
                    jq('#saveCreate').on('click', function () {
                        const formData = jq('#createForm').serialize();
                        jq.ajax({
                            url: '/superadmin/users',
                            method: 'POST',
                            data: formData,
                            success: function (data) {
                                if (data.success) {
                                    jq('#createModal').modal('hide');
                                    const table = jq('#usersTable').DataTable();
                                    const newRow = table.row.add([
                                        `${data.user.f_name} ${data.user.l_name}`,
                                        data.user.email,
                                        data.user.role,
                                        data.user.kyc_status,
                                        `<button class="btn btn-sm btn-info view-btn" data-id="${data.user._id}"><i class="fas fa-eye"></i></button>
               <button class="btn btn-sm btn-primary edit-btn" data-id="${data.user._id}">Edit</button>
               <button class="btn btn-sm btn-danger delete-btn" data-id="${data.user._id}">Delete</button>`
                                    ]).draw().node();
                                    jq(newRow).attr('data-user-id', data.user._id);
                                    alert(data.message);
                                } else {
                                    alert(data.message || 'Create failed');
                                }
                            },
                            error: function (xhr) {
                                alert(xhr.responseJSON ? xhr.responseJSON.message : 'Error creating user');
                            }
                        });
                    });

                    // View Details (AJAX GET)
                    jq(document).on('click', '.view-btn', function () {
                        const id = jq(this).data('id');
                        if (!id) return alert('User ID missing');

                        jq.ajax({
                            url: `/superadmin/users/${id}`,
                            method: 'GET',
                            success: function (data) {
                                if (data.success) {
                                    const u = data.user;
                                    let blacklistHtml = '';
                                    if (u.blacklistStatus) {
                                        blacklistHtml = `<p><strong>Blacklisted:</strong> Yes (Reason: ${u.blacklistReason || 'No reason provided'})</p>`;
                                    } else {
                                        blacklistHtml = '<p><strong>Blacklisted:</strong> No</p>';
                                    }
                                    let detailsHtml = `
              <div class="row">
                <div class="col-md-6">
                  <h6>Personal Info</h6>
                  <p><strong>Name:</strong> ${u.f_name} ${u.l_name}</p>
                  <p><strong>Email:</strong> ${u.email}</p>
                  <p><strong>Mobile:</strong> ${u.mobile_no || 'N/A'}</p>
                  <p><strong>DOB:</strong> ${u.dob ? new Date(u.dob).toLocaleDateString() : 'N/A'}</p>
                  <p><strong>Role:</strong> ${u.role}</p>
                  <p><strong>KYC Status:</strong> ${u.kyc_status}</p>
                  <p><strong>User Status:</strong> ${u.user_status || 'N/A'}</p>
                  ${blacklistHtml}
                </div>
                <div class="col-md-6">
                  <h6>Business Info</h6>
                  <p><strong>Country:</strong> ${u.country || 'N/A'}</p>
                  <p><strong>Category:</strong> ${u.category || 'N/A'}</p>
                  <p><strong>Shop Name:</strong> ${u.shopname || 'N/A'}</p>
                  <p><strong>Shop Address:</strong> ${u.shopadd || 'N/A'}</p>
                  <p><strong>No. of Employees:</strong> ${u.no_of_emp || 0}</p>
                  <p><strong>Address:</strong> ${u.address || 'N/A'}</p>
                </div>
              </div>
              <div class="row mt-3">
                <div class="col-md-12">
                  <h6>Documents</h6>
                  ${u.profilePicture ? `<img src="${u.profilePicture}" alt="Profile" style="max-width:100px;">` : ''}
                  ${u.adhar_photo ? `<a href="${u.adhar_photo}" target="_blank">View Aadhaar</a>` : ''}
                  ${u.pan_photo ? `<a href="${u.pan_photo}" target="_blank">View PAN</a>` : ''}
                  ${u.shop_licence ? `<a href="${u.shop_licence}" target="_blank">View Shop Licence</a>` : ''}
                  <p><strong>Aadhaar No:</strong> ${u.adhar_no || 'N/A'}</p>
                </div>
              </div>
            `;
                                    jq('#userDetailsBody').html(detailsHtml);
                                    jq('#viewModal').modal('show');
                                }
                            },
                            error: function () { alert('Error fetching details'); }
                        });
                    });

                    // Delete User
                    jq(document).on('click', '.delete-btn', function () {
                        const id = jq(this).data('id');
                        if (!id) {
                            alert('Error: User ID not found.');
                            return;
                        }
                        if (!confirm('Delete this user?')) return;

                        const row = jq(this).closest('tr');
                        jq.ajax({
                            url: `/superadmin/users/${id}`,
                            method: 'DELETE',
                            success: function (data) {
                                if (data.success) {
                                    row.fadeOut(300, function () { jq(this).remove(); });
                                    alert(data.message);
                                } else {
                                    alert(data.message || 'Delete failed');
                                }
                            },
                            error: function (xhr) {
                                console.error('AJAX Error:', xhr);
                                const err = xhr.responseJSON ? xhr.responseJSON.message : 'Error deleting user';
                                alert(err);
                            }
                        });
                    });
                    jq(document).on('change', '#blacklistStatus', function() {
                    if (jq(this).is(':checked')) {
                        jq('#blacklistReasonBox').slideDown();
                    } else {
                        jq('#blacklistReasonBox').slideUp();
                        jq('#blacklistReason').val('');
                    }
                    });
                    // Edit User (GET + Modal)
                    jq(document).on('click', '.edit-btn', function () {
                        const id = jq(this).data('id');
                        jq('#editUserId').val(id);

                        jq.ajax({
                            url: `/superadmin/users/${id}`,
                            method: 'GET',
                            success: function (data) {
                                if (data.success) {
                                    const u = data.user;
                                    jq('#editForm input[name="f_name"]').val(u.f_name);
                                    jq('#editForm input[name="l_name"]').val(u.l_name);
                                    jq('#editForm input[name="email"]').val(u.email);
                                    jq('#editForm select[name="role"]').val(u.role);
                                    jq('#editForm select[name="kyc_status"]').val(u.kyc_status);
                                    jq('#editForm input[name="blacklistStatus"]').prop('checked', u.blacklistStatus || false);
                                    jq('#editForm textarea[name="blacklistReason"]').val(u.blacklistReason || '');
                                    if (u.blacklistStatus) {
                                    jq('#blacklistReasonBox').show();
                                    } else {
                                    jq('#blacklistReasonBox').hide();
                                    }
                                    jq('#editModal').modal('show');
                                }
                            },
                            error: function () { alert('Error fetching user'); }
                        });
                    });

                    // Save Edit
                    jq('#saveEdit').on('click', function () {
                        const id = jq('#editUserId').val();
                        const formData = jq('#editForm').serialize();
                        jq.ajax({
                            url: `/superadmin/users/${id}`,
                            method: 'PUT', // Or POST
                            data: formData,
                            success: function (data) {
                                if (data.success) {
                                    jq('#editModal').modal('hide');
                                    location.reload(); // Simple: Reload to update table (or update row cells manually)
                                    alert(data.message);
                                }
                            },
                            error: function () { alert('Error updating user'); }
                        });
                    });

                });
            </script>


            <script src="/superadmin-frontend/js/vanilla-utils.js"></script>
            <script
                src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
            <script src="/superadmin-frontend/vendor/perfect-scrollbar/perfect-scrollbar-1.5.6.min.js"></script>
            <script src="/superadmin-frontend/vendor/chartjs/chart.umd.js-4.5.0.min.js"></script>

            <!-- Main JS-->
            <script src="/superadmin-frontend/vendor/bootstrap-5.3.8.bundle.min.js"></script>
            <script src="/superadmin-frontend/js/bootstrap5-init.js"></script>
            <script src="/superadmin-frontend/js/main-vanilla.js"></script>
            <script src="/superadmin-frontend/js/swiper-bundle-11.2.10.min.js"></script>
            <script src="/superadmin-frontend/js/aos.js"></script>
            <script src="/superadmin-frontend/js/modern-plugins.js"></script>