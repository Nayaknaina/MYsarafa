    <div class="page-container">
        <!-- HEADER DESKTOP -->
        <div class="main-content">
           {{> superdesktopheader}}
            <div class="section__content section__content--p30">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="overview-wrap">
                                <h2 class="title-1">Manage Groups</h2>
                                <button class="au-btn au-btn-icon au-btn--blue">
                                    <i class="zmdi zmdi-plus"></i>Create New Group</button>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <h2 class="title-1 m-b-25">Groups</h2>
                            <div class="table-responsive table--no-card m-b-40">
                                <table id="groupsTable" class="table table-borderless table-striped table-earning">
                                    <thead>
                                        <tr>
                                            <th>Group Type</th>
                                            <th>Group Name</th>
                                            <th>Total Members</th>
                                            <th>KYC Required?</th>
                                            <th>Created By</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {{#each groups}}
                                        <tr>
                                            <td>{{g_type}}</td>
                                            <td>{{g_name}}</td>
                                            <td>{{total_mem}}</td>
                                            <td>{{#if is_kyc_req}}Yes{{else}}No{{/if}}</td>
                                            <td>{{createdBy.f_name}} {{createdBy.l_name}}</td>
                                            <td>
                                                <button class="btn btn-sm btn-info view-btn" data-id="{{_id}}" title="View Details"><i class="fas fa-eye"></i></button>
                                                <button class="btn btn-sm btn-primary edit-btn" data-id="{{_id}}">Edit</button>
                                                <button class="btn btn-sm btn-danger delete-btn" data-id="{{_id}}">Delete</button>
                                            </td>
                                        </tr>
                                        {{/each}}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                   
                    <!-- Tasks/Messages: Unchanged -->
                </div>
            </div>
             <!-- NEW: Create Group Modal -->
                    <div  class="modal fade" id="createModal" tabindex="-1" data-bs-backdrop="false">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Create New Group</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <form id="createForm">
                                        <div class="mb-3">
                                            <label class="form-label">Group Name *</label>
                                            <input type="text" class="form-control" name="g_name" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Group Type *</label>
                                            <select class="form-control" name="g_type" required>
                                                <option value="">Select Type</option>
                                                {{#each gTypeOptions}}
                                                <option value="{{this}}">{{this}}</option>
                                                {{/each}}
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Created By *</label>
                                            <select class="form-control" name="createdBy" required>
                                                <option value="">Select Creator</option>
                                                {{#each allUsers}}
                                                <option value="{{_id}}">{{f_name}} {{l_name}}</option>
                                                {{/each}}
                                            </select>
                                        </div>
                                        <div class="form-check mb-3">
                                            <input class="form-check-input" type="checkbox" name="is_kyc_req" id="is_kyc_req">
                                            <label class="form-check-label" for="is_kyc_req">KYC Required?</label>
                                        </div>
                                    </form>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="button" class="btn btn-primary" id="saveCreate">Create Group</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- NEW: Edit Group Modal -->
                    <div class="modal fade" id="editModal" tabindex="-1" data-bs-backdrop="static">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Edit Group</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <form id="editForm">
                                        <input type="hidden" id="editGroupId" name="_id">
                                        <div class="mb-3">
                                            <label class="form-label">Group Name</label>
                                            <input type="text" class="form-control" name="g_name" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Group Type</label>
                                            <select class="form-control" name="g_type" required>
                                                {{#each gTypeOptions}}
                                                <option value="{{this}}">{{this}}</option>
                                                {{/each}}
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Created By</label>
                                            <select class="form-control" name="createdBy" required>
                                                {{#each allUsers}}
                                                <option value="{{_id}}">{{f_name}} {{l_name}}</option>
                                                {{/each}}
                                            </select>
                                        </div>
                                        <div class="form-check mb-3">
                                            <input class="form-check-input" type="checkbox" name="is_kyc_req" id="editIsKycReq">
                                            <label class="form-check-label" for="editIsKycReq">KYC Required?</label>
                                        </div>
                                    </form>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    <button type="button" class="btn btn-primary" id="saveEdit">Save Changes</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- NEW: View Group Modal -->
                    <div class="modal fade" id="viewModal" tabindex="-1">
                        <div class="modal-dialog modal-xl">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Group Details</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body" id="groupDetailsBody">
                                    <!-- Populated via JS -->
                                </div>
                            </div>
                        </div>
                    </div>

        </div>
    </div>
</div>

            <script src="https://code.jquery.com/jquery-3.7.1.js"></script>

            <!-- DataTables JS --><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

            <script src="https://cdn.datatables.net/2.3.4/js/dataTables.js"></script>
            <script src="https://cdn.datatables.net/2.3.4/js/dataTables.bootstrap5.js"></script>

<script>
    const jq = jQuery.noConflict(false);
    jq(document).ready(function () {
        console.log(1);
        // Init DataTable
        jq('#groupsTable').DataTable();

        // Create Modal Open
        jq('.au-btn--blue').on('click', function (e) {
            e.preventDefault();
            jq('#createForm')[0].reset();
            jq('#createModal').modal('show');
        });

        // Create Group
        jq('#saveCreate').on('click', function () {
            const formData = jq('#createForm').serialize();
            jq.ajax({
                url: '/superadmin/groups',
                method: 'POST',
                data: formData,
                success: function (data) {
                    if (data.success) {
                        jq('#createModal').modal('hide');
                        const table = jq('#groupsTable').DataTable();
                        const newRow = table.row.add([
                            data.group.g_type,
                            data.group.g_name,
                            data.group.total_mem,
                            data.group.is_kyc_req ? 'Yes' : 'No',
                            `${data.group.user.f_name} ${data.group.user.l_name}`, // FIXED: user
                            `<button class="btn btn-sm btn-info view-btn" data-id="${data.group._id}"><i class="fas fa-eye"></i></button>
                             <button class="btn btn-sm btn-primary edit-btn" data-id="${data.group._id}">Edit</button>
                             <button class="btn btn-sm btn-danger delete-btn" data-id="${data.group._id}">Delete</button>`
                        ]).draw().node();
                        jq(newRow).attr('data-group-id', data.group._id);
                        alert(data.message);
                    } else {
                        alert(data.message || 'Create failed');
                    }
                },
                error: function (xhr) {
                    alert(xhr.responseJSON ? xhr.responseJSON.message : 'Error creating group');
                }
            });
        });

        // View Group Details
        jq(document).on('click', '.view-btn', function () {
            const id = jq(this).data('id');
            if (!id) return alert('Group ID missing');
            jq.ajax({
                url: `/superadmin/groups/${id}`,
                method: 'GET',
                success: function (data) {
                    if (data.success) {
                        const g = data.group;
                        let detailsHtml = `
                            <div class="row">
                                <div class="col-md-6">
                                    <h6>Group Info</h6>
                                    <p><strong>Name:</strong> ${g.g_name}</p>
                                    <p><strong>Type:</strong> ${g.g_type}</p>
                                    <p><strong>Description:</strong> ${g.description || 'N/A'}</p>
                                    <p><strong>Total Members:</strong> ${g.total_mem}</p>
                                    <p><strong>Total Posts:</strong> ${g.total_post}</p>
                                    <p><strong>KYC Required:</strong> ${g.is_kyc_req ? 'Yes' : 'No'}</p>
                                    <p><strong>Amount:</strong> ${g.amount}</p>
                                    <p><strong>Amount Description:</strong> ${g.amount_description || 'N/A'}</p>
                                    <p><strong>Created By:</strong> ${g.user.f_name} ${g.user.l_name}</p> <!-- FIXED: user -->
                                    <p><strong>Created At:</strong> ${new Date(g.createdAt).toLocaleDateString()}</p>
                                </div>
                                <div class="col-md-6">
                                    <h6>Media</h6>
                                    ${g.g_cover ? `<img src="${g.g_cover}" alt="Cover" style="max-width:200px;">` : ''}
                                    ${g.qr_code ? `<a href="${g.qr_code}" target="_blank">View QR Code</a>` : ''}
                                </div>
                            </div>
                        `;
                        jq('#groupDetailsBody').html(detailsHtml);
                        jq('#viewModal').modal('show');
                    }
                },
                error: function () { alert('Error fetching details'); }
            });
        });

        // Delete Group
        jq(document).on('click', '.delete-btn', function () {
            const id = jq(this).data('id');
            if (!id) {
                alert('Error: Group ID not found.');
                return;
            }
            if (!confirm('Delete this group?')) return;
            const row = jq(this).closest('tr');
            jq.ajax({
                url: `/superadmin/groups/${id}`,
                method: 'DELETE',
                success: function (data) {
                    if (data.success) {
                        row.fadeOut(300, function () { jq(this).remove(); });
                        alert(data.message);
                    } else {
                        alert(data.message || 'Delete failed');
                    }
                },
                error: function (xhr) {
                    console.error('AJAX Error:', xhr);
                    const err = xhr.responseJSON ? xhr.responseJSON.message : 'Error deleting group';
                    alert(err);
                }
            });
        });

        // Edit Group
        jq(document).on('click', '.edit-btn', function () {
            const id = jq(this).data('id');
            jq('#editGroupId').val(id);
            jq.ajax({
                url: `/superadmin/groups/${id}`,
                method: 'GET',
                success: function (data) {
                    if (data.success) {
                        const g = data.group;
                        jq('#editForm input[name="g_name"]').val(g.g_name);
                        jq('#editForm select[name="g_type"]').val(g.g_type);
                        jq('#editForm select[name="user"]').val(g.user._id); // FIXED: user._id
                        jq('#editForm textarea[name="description"]').val(g.description);
                        jq('#editForm input[name="amount"]').val(g.amount);
                        jq('#editForm input[name="amount_description"]').val(g.amount_description);
                        jq('#editForm input[name="is_kyc_req"]').prop('checked', g.is_kyc_req);
                        jq('#editModal').modal('show');
                    }
                },
                error: function () { alert('Error fetching group'); }
            });
        });

        // Save Edit Group
        jq('#saveEdit').on('click', function () {
            const id = jq('#editGroupId').val();
            const formData = jq('#editForm').serialize();
            jq.ajax({
                url: `/superadmin/groups/${id}`,
                method: 'POST',
                data: formData,
                success: function (data) {
                    if (data.success) {
                        jq('#editModal').modal('hide');
                        location.reload();
                        alert(data.message);
                    } else {
                        alert(data.message || 'Update failed');
                    }
                },
                error: function (xhr) {
                    alert(xhr.responseJSON ? xhr.responseJSON.message : 'Error updating group');
                }
            });
        });
    });
</script>

