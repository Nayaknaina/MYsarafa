            <script src="/superadmin-frontend/js/main-vanilla.js"></script>
            <script src="/superadmin-frontend/js/swiper-bundle-11.2.10.min.js"></script>
            <script src="/superadmin-frontend/js/aos.js"></script>
            <script src="/superadmin-frontend/js/modern-plugins.js"></script>