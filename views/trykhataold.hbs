  </div>


  <script>
    // ──────────────────────────────────────────────────────────────
    // GLOBAL VARIABLES (declare only once)
    // ──────────────────────────────────────────────────────────────
    let selectedType = 'cash';
    let transactionType = 'gave';
    let currentCustomerId = null;          // ← ONE declaration only

    // ──────────────────────────────────────────────────────────────
    // PANEL CONTROL (minimize / open)
    // ──────────────────────────────────────────────────────────────
    function toggleMinimize() {
      const container = document.getElementById('addPanelContainer');
      container.classList.add('minimized');
    }

    function openAddPanel() {
      const container = document.getElementById('addPanelContainer');
      container.classList.remove('minimized');
    }
    function getInitials(name) {
      if (!name || typeof name !== 'string') return '?';
      return name
        .trim()
        .split(' ')
        .map(word => word[0])
        .join('')
        .toUpperCase()
        .slice(0, 2);
    }

    function sendReminder(type) {
      if (!currentCustomerId) return alert('Select a customer first');

      const cust = window.preloadedCustomer || {};
      const mobile = cust.mobile_no || prompt('Enter 10-digit mobile number:');
      if (!mobile || !/^\d{10}$/.test(mobile)) return alert('Enter valid 10-digit number');

      const name = cust.name || 'Customer';
      const balance = Math.abs(cust.amount_balance || 0);
      const item = balance > 0 ? 'cash' : (cust.gold_balance > 0 ? 'gold' : 'silver');
      const unit = item === 'cash' ? '₹' : 'g';
      const msg = `Hi ${name}, your balance is ${unit}${balance.toLocaleString()}. Please settle.`;

      const url = type === 'whatsapp'
        ? `https://wa.me/91${mobile}?text=${encodeURIComponent(msg)}`
        : `sms:91${mobile}?body=${encodeURIComponent(msg)}`;

      window.open(url, '_blank');
    }

    function updateBalances(bal) {
      // Update all elements that may show these balances (mobile + desktop copies)
      setTextByIdAll('detailCashBal', `₹${(bal.cash || 0).toLocaleString()}`);
      setTextByIdAll('detailGoldBal', `${(bal.gold || 0).toFixed(2)}g`);
      setTextByIdAll('detailSilverBal', `${(bal.silver || 0).toFixed(2)}g`);

    }

    // Utility: set text for all elements that (incorrectly) share the same id in DOM
    function setTextByIdAll(id, text) {
      try {
        var els = document.querySelectorAll('[id="' + id + '"]');
        if (!els || els.length === 0) return;
        els.forEach(function (el) { el.innerText = text; });
      } catch (e) { console.error('setTextByIdAll', e); }
    }

    function addEntry(entry) {
      // Insert the new entry into all entry lists (mobile + desktop)
      const lists = document.querySelectorAll('.detailEntriesList');
      if (!lists || lists.length === 0) return;

      const div = document.createElement('div');
      div.className = 'entry-item';
      div.innerHTML = `
    <div>
      <div class="entry-date">Just now</div>
      <div class="entry-bal">Bal. ₹${(entry.balance && entry.balance.cash) || 0} | ${(entry.balance && entry.balance.gold) || 0}g</div>
    </div>
    <div class="entry-amount ${entry.transactionType === 'got' ? 'you-got' : ''}">
      ${entry.transactionType === 'gave' ? 'YOU GAVE' : 'YOU GOT'}
      ${entry.item === 'cash' ? '₹' : ''}${entry.amount}${entry.item !== 'cash' ? 'g' : ''}
    </div>`;

      lists.forEach(list => {
        // remove empty message if present
        const empty = list.querySelector('.no-entries');
        if (empty) list.innerHTML = '';
        list.insertBefore(div.cloneNode(true), list.firstChild);
      });
    }

    function renderCustomer(cust) {
      if (!cust) return;

      // Ensure we don't create multiple overlays
      if (!document.getElementById('loading-overlay')) {
        const loadingDiv = document.createElement('div');
        loadingDiv.id = 'loading-overlay';
        loadingDiv.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(255,255,255,0.8);display:flex;justify-content:center;align-items:center;z-index:99999;';
        loadingDiv.innerHTML = 'Loading...';
        document.body.appendChild(loadingDiv);
      }

      try {
        // Update UI visibility
        const detailPanel = document.getElementById('detailPanel');
        const noState = document.getElementById('noCustomerState');
        if (detailPanel) detailPanel.style.display = 'block';
        if (noState) noState.style.display = 'none';

        // Update customer info (update all duplicates)
        setTextByIdAll('detailCustomerName', cust.name || '');
        setTextByIdAll('detailAvatar', getInitials(cust.name));

        // Update balances first to ensure they're visible (accept multiple key names)
        const bal = {
          cash: (cust.cash != null) ? cust.cash : (cust.amount_balance != null ? cust.amount_balance : 0),
          gold: (cust.gold != null) ? cust.gold : (cust.gold_balance != null ? cust.gold_balance : 0),
          silver: (cust.silver != null) ? cust.silver : (cust.silver_balance != null ? cust.silver_balance : 0)
        };
        updateBalances(bal);

        // Update entries into both lists
        const entriesLists = document.querySelectorAll('.detailEntriesList');

        if (!cust.entries || cust.entries.length === 0) {
          entriesLists.forEach(list => {
            list.innerHTML = `<div class="no-entries"><p>No entries till now</p><p class="add-hint">Click down here to add a transaction/entry</p></div>`;
          });
        } else {
          entriesLists.forEach(list => {
            let entriesHTML = '';
            cust.entries.forEach(e => {
              const cashBal = (e.balance && e.balance.cash) ? (e.balance.cash).toLocaleString() : '0';
              const goldBal = (e.balance && e.balance.gold) ? (e.balance.gold).toFixed(2) : '0.00';
              entriesHTML += `
                <div class="entry-item">
                  <div>
                    <div class="entry-date">${new Date(e.date).toLocaleDateString()} • ${timeAgo(e.date)}</div>
                    <div class="entry-bal">Bal. ₹${cashBal} | ${goldBal}g</div>
                  </div>
                  <div class="entry-amount ${e.transactionType === 'got' ? 'you-got' : ''}">
                    ${e.transactionType === 'gave' ? 'YOU GAVE' : 'YOU GOT'}
                    ${e.item === 'cash' ? '₹' : ''}${e.amount}${e.item !== 'cash' ? 'g' : ''}
                  </div>
                </div>`;
            });
            list.innerHTML = entriesHTML;
          });
        }

      } catch (e) { console.error('renderCustomer', e); }
      finally {
        // Remove loading overlay
        const loadingOverlay = document.getElementById('loading-overlay');
        if (loadingOverlay) loadingOverlay.remove();
      }
    }

    // Helper function for time ago display
    function timeAgo(date) {
      const seconds = Math.floor((new Date() - new Date(date)) / 1000);
      const intervals = {
        year: 31536000,
        month: 2592000,
        week: 604800,
        day: 86400,
        hour: 3600,
        minute: 60
      };

      for (let [unit, secondsInUnit] of Object.entries(intervals)) {
        const interval = Math.floor(seconds / secondsInUnit);
        if (interval >= 1) {
          return interval === 1 ? `1 ${unit} ago` : `${interval} ${unit}s ago`;
        }
      }
      return 'Just now';
    }

    // ──────────────────────────────────────────────────────────────
    // SAVE TRANSACTION
    // ──────────────────────────────────────────────────────────────
    async function saveTransaction() {
      if (!currentCustomerId) return alert('Please select a customer first');

      const amount = parseFloat(document.getElementById('amountInput').value);
      if (!amount || amount <= 0) return alert('Enter a valid amount');

      const payload = {
        customerId: currentCustomerId,
        type: selectedType,           // 'cash', 'gold', 'silver'
        amount,
        transactionType               // 'gave' or 'got'
      };

      try {
        const res = await fetch('/ledger/transaction/new', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const data = await res.json();
        console.log("transaction save response", data);
        if (!res.ok) throw new Error(data.error || 'Failed to save');

        // Update UI
        updateBalances(data.balances);
        addEntry(data.entry);
        document.getElementById('amountInput').value = '';

        // Auto-minimize
        setTimeout(toggleMinimize, 800);
      } catch (e) {
        alert('Error: ' + e.message);
      }
    }

    // ──────────────────────────────────────────────────────────────
    // LOAD CUSTOMER (Desktop only) – THIS IS THE FUNCTION THAT WAS MISSING
    // ──────────────────────────────────────────────────────────────
    async function loadCustomer(id) {
      if (window.innerWidth < 768) {
        window.location.href = `/ledger/${id}`;
        return;
      }

      currentCustomerId = id;

      try {
        // Show loading state immediately
        const loadingDiv = document.createElement('div');
        loadingDiv.id = 'loading-overlay';
        loadingDiv.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(255,255,255,0.8);display:flex;justify-content:center;align-items:center;z-index:9999;';
        loadingDiv.innerHTML = 'Loading...';
        document.body.appendChild(loadingDiv);

        // Clear previous data first
        document.getElementById('detailCashBal').innerText = '₹0';
        document.getElementById('detailGoldBal').innerText = '0g';
        document.getElementById('detailSilverBal').innerText = '0g';
        document.querySelectorAll('.detailEntriesList').forEach(list => {
          list.innerHTML = '<div class="no-entries"><p>Loading entries...</p></div>';
        });

        // Try to get preloaded data first
        const preloaded = window.preloadedCustomer;
        if (preloaded && preloaded._id === id) {
          renderCustomer(preloaded);
          window.history.pushState({}, '', `/ledger/${id}`);
          return;
        }

        // Fetch fresh data
        const res = await fetch(`/ledger/customer/${id}`);
        if (!res.ok) throw new Error('Customer not found');

        const cust = await res.json();
        if (!cust) throw new Error('Invalid customer data');

        // Update the customer data in memory
        window.preloadedCustomer = cust;

        // Render the customer data
        renderCustomer(cust);
        window.history.pushState({}, '', `/ledger/${id}`);

      } catch (err) {
        console.error('Error loading customer:', err);
        alert('Failed to load customer data');
      } finally {
        // Always remove loading overlay
        const loadingOverlay = document.getElementById('loading-overlay');
        if (loadingOverlay) loadingOverlay.remove();
      }
    }

    // ──────────────────────────────────────────────────────────────
    // TYPE / GAVE-GOT BUTTONS
    // ──────────────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
      // Type buttons
      document.querySelectorAll('.type-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          selectedType = btn.dataset.type;

          const input = document.getElementById('amountInput');
          input.placeholder = selectedType === 'cash'
            ? 'Enter amount in ₹'
            : `Enter grams of ${selectedType.toUpperCase()}`;

          document.getElementById('gaveBtn').innerHTML = selectedType === 'cash' ? 'YOU GAVE ₹' : 'YOU GAVE g';
          document.getElementById('gotBtn').innerHTML = selectedType === 'cash' ? 'YOU GOT ₹' : 'YOU GOT g';
        });
      });

      // Gave / Got
      document.getElementById('gaveBtn').onclick = () => {
        document.querySelectorAll('.gave-got-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('gaveBtn').classList.add('active');
        transactionType = 'gave';
      };
      document.getElementById('gotBtn').onclick = () => {
        document.querySelectorAll('.gave-got-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('gotBtn').classList.add('active');
        transactionType = 'got';
      };



    });

    // ──────────────────────────────────────────────────────────────
    // FILTER / SORT (unchanged – you can keep your own implementation)
    // ──────────────────────────────────────────────────────────────
    function filterCustomers() {
      const term = document.querySelector('.search-box input').value.toLowerCase();
      document.querySelectorAll('.customer-item').forEach(item => {
        const name = item.querySelector('.customer-name').innerText.toLowerCase();
        item.style.display = name.includes(term) ? 'flex' : 'none';
      });
    }

    function sortCustomers() { /* implement if you need */ }
  </script>
