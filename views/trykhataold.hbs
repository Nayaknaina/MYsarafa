<body>
  {{> header}}

  <div class="main-container">
    <!-- Sidebar -->
    {{> sidebar}}

    <!-- ==================== MOBILE VIEW (unchanged) ==================== -->
    <div class="mobile-container">
      <div class="container">
        <div class="header-mobile">
          <a href="/" class="back-btn">Back</a>
          <div class="customer-name">{{customer.name}}</div>
          <div></div>
        </div>

        <div class="balances">
          <div class="bal-box cash">
            <div class="bal-label">CASH</div>
            <div class="bal-value" id="detailCashBal">₹{{formatNumber customer.cash}}</div>
          </div>
          <div class="bal-box gold">
            <div class="bal-label">GOLD</div>
            <div class="bal-value" id="detailGoldBal">{{formatGold customer.gold}}g</div>
          </div>
          <div class="bal-box silver">
            <div class="bal-label">SILVER</div>
            <div class="bal-value" id="detailSilverBal">{{formatGold customer.silver}}g</div>
          </div>
        </div>

        <div class="actions">
          <button class="action-btn pdf">
            <i class="fas fa-file-pdf"></i> PDF
          </button>
          <button class="action-btn reminder">
            <i class="fas fa-bell"></i> Reminder
          </button>
          <button class="action-btn sms">
            <i class="fas fa-sms"></i> SMS
          </button>
        </div>

        <div class="entries detailEntriesList">
          {{#if customer.entries.length}}
          {{#each customer.entries}}
          <div class="entry-item">
            <div>
              <div class="entry-date">{{formatDate date}} • {{timeAgo date}}</div>
              <div class="entry-bal">Bal. {{formatNumber ../customer.cash}} | {{formatGold ../customer.gold}}g</div>
            </div>
            <div class="entry-amount {{#if (eq type " got")}}you-got{{else}}{{/if}}">
              {{#if (eq type "gave")}}YOU GAVE{{else}}YOU GOT{{/if}}
              {{#if (eq item "cash")}}₹{{else}}{{/if}}{{amount}}{{#unless (eq item "cash")}}g{{/unless}}
            </div>
          </div>
          {{/each}}
          {{else}}
          <div class="no-entries">
            <p>No entries till now</p>
            <p class="add-hint">Click down here to add a transaction/entry</p>
          </div>
          {{/if}}
        </div>

        <div class="fab-container"></div>
        <button class="fab" onclick="toggleAddPanel()">+</button>
      </div>
    </div>

    <!-- ==================== DESKTOP: Split View ==================== -->
    <div class="desktop-layout">
      <!-- LEFT: Sidebar -->
      <div class="sidebar-panel">
        <div class="sidebar-header">Mysarafa KhataBook</div>

        <div class="total-summary">
          <div class="total-item">
            <div class="total-label-cash">CASH</div>
            <div class="total-value">₹{{formatNumber totalCash}}</div>
          </div>
          <div class="total-item">
            <div class="total-label-gold">GOLD</div>
            <div class="total-value {{#if (gt totalGold 0)}}text-success{{else}}text-danger{{/if}}">
              {{formatGold totalGold}}g
            </div>
          </div>
          <div class="total-item">
            <div class="total-label-silver">SILVER</div>
            <div class="total-value {{#if (gt totalSilver 0)}}text-success{{else}}text-danger{{/if}}">
              {{formatGold totalSilver}}g
            </div>
          </div>
        </div>

        <div class="search-filters">
          <div class="search-box" style="position:relative;">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Name or Phone Number" onkeyup="filterCustomers()" />
          </div>
          <select class="filter-select" onchange="filterCustomers()">
            <option>Filter By</option>
            <option value="gold">Gold</option>
            <option value="silver">Silver</option>
            <option value="cash">Cash</option>
          </select>
          <select class="sort-select" onchange="sortCustomers()">
            <option>Sort By</option>
            <option value="name">Name</option>
            <option value="recent">Recent</option>
            <option value="amount">Amount</option>
          </select>
        </div>

        <div class="customer-list" id="customerList">
          {{#if customers.length}}
          {{#each customers}}
          <div class="customer-item" onclick="loadCustomer('{{_id}}')">
            <div class="avatar">{{initials name}}</div>
            <div class="customer-name">{{name}}</div>
          </div>
          {{/each}}
          {{else}}
          <!-- EMPTY STATE (Exact from Screenshot) -->
          <div class="empty-state-list">
            <!-- Replace src with your actual image path -->
            <img
              src="/assets/images/happy-excited-man-holding-laptop-money-make-earn-money-online-internet_199628-239.jpg"
              alt="No customers" class="empty-image" />

            <div class="empty-text">No party data available for applied filters</div>
            <div class="empty-subtext">Try adjusting filters or add a new customer</div>

            {{!-- <div class="no-customer">
              <div class="no-customer-icon"><i class="far fa-user-circle"></i></div>
              <div class="no-customer-text">No customer selected</div>
            </div> --}}
          </div>
          {{/if}}
        </div>

        <div class="sidebar-footer">
          <button class="bulk-upload-btn" onclick="openBulkUpload()">
            + Bulk Upload Customers
          </button>
          <button class="add-customer-btn" onclick="openAddCustomer()">
            + Add Customer
          </button>
        </div>
      </div>

      <!-- RIGHT: Detail Panel (same markup as mobile) -->
      <div class="detail-panel" id="detailPanel" style="display: none;">
        <div class="container">
          <div class="detail-header-name">
            <div class="avatar" id="detailAvatar">?</div>
