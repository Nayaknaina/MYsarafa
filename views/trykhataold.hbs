          <div class="fab-container">
            <!-- ==================== Minimizable Add Panel ==================== -->
            <div class="add-panel-container" id="addPanelContainer">
              <div class="add-panel-header">
                <!-- + Button (LEFT - Opens full panel) -->
                <button class="open-btn" onclick="openAddPanel()">+</button>

                <!-- Select Type Buttons -->
                <div class="select-type">
                  <button class="type-btn active" data-type="cash">CASH</button>
                  <button class="type-btn" data-type="gold">GOLD</button>
                  <button class="type-btn" data-type="silver">SILVER</button>
                </div>

                <!-- Minimize Button (RIGHT) -->
                <button class="minimize-btn" onclick="toggleMinimize()">−</button>
              </div>

              <!-- Full Panel Body (hidden when minimized) -->
              <div class="add-panel-body" id="addPanelBody">
                <div class="input-group">
                  <input type="number" id="amountInput" placeholder="Enter amount/grams" />
                </div>
                <div class="input-group">
                  <button class="gave-got-btn gave active" id="gaveBtn">YOU GAVE ₹</button>
                  <button class="gave-got-btn got" id="gotBtn">YOU GOT ₹</button>
