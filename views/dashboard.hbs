                                    {{!-- <span class="rate-change {{silverRate.changes.price}}"> --}}
                                        {{!-- <span class="rate-change {{silverRate.silverTrend}}">


                                            {{#if_eq silverRate.silverTrend 'up'}}
                                            Silver rate has increased by
                                            <span class="text-green-600 font-semibold">₹{{silverRate.silver_ch}}</span>
                                            from yesterday
                                            {{else}}
                                            Silver rate has decreased by
                                            <span class="text-red-600 font-semibold">₹{{silverRate.silver_ch}}</span>
                                            from yesterday
                                            {{/if_eq}}
                                        </span> --}}
                                        <span class="rate-change {{silverRate.silverTrend}}">

                                            {{#if_eq silverRate.silverTrend 'up'}}

                                            <i class="fas fa-arrow-up text-green-600"></i>
                                            Silver rate increased by
                                            <span class="text-green-600 font-semibold">
                                                ₹{{silverRate.silver_ch}}
                                            </span>
                                            from yesterday

                                            {{else}}

                                            {{#if_eq silverRate.silverTrend 'down'}}

                                            <i class="fas fa-arrow-down text-red-600"></i>
                                            Silver rate decreased by
                                            <span class="text-red-600 font-semibold">
                                                ₹{{silverRate.silver_ch}}
                                            </span>
                                            from yesterday

                                            {{else}}

                                            <i class="fas fa-minus text-gray-500"></i>
                                            Silver rate unchanged from yesterday

                                            {{/if_eq}}

                                            {{/if_eq}}

                                        </span>
                                </div>
                            </div>

                            <div class="rate-chart">
                                <img src="/img/silver_graph.png" alt="">
                            </div>
                        </div>
                        {{/if}}
                    </div>
                </section>


                {{> businessScroller businesses=featuredBusinesses showAddButton=isLeader}}

                <section class="live-rates-preview bg-white rounded-xl p-4 mb-6 shadow-md">
                    <div class="flex items-center justify-between mb-2">
                        <h2 class="text-lg font-semibold text-gray-800 flex items-center">
                            <i class="fas fa-wallet mr-2 text-yellow-600"></i> Gold, Silver & Cash Summary
                        </h2>
                        <a href="/ledger/trykhatabook?type=customer"
                            class="view-btn inline-flex items-center px-3 py-1 bg-blue-600 text-white text-sm font-medium rounded-full hover:bg-blue-700 transition-colors">
                            <i class="fas fa-eye mr-1"></i>
                            +Add Entry
                        </a>
                    </div>

                    <div class="grid grid-cols-3 gap-3">

                        {{!-- GOLD CARD --}}
                        {{!-- <div
                            class="rate-item bg-gray-50 p-3 rounded-lg text-center hover:bg-gray-100 transition-colors">
                            <span class="text-xs text-gray-600">Gold Total (gram)</span>
                            <p class="rate-value text-lg font-bold 
                            {{#if (gt totals.totalGold 0)}}text-green-600
