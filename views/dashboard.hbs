                                            </span>
                                            from yesterday

                                            {{else}}

                                            <i class="fas fa-minus text-gray-500"></i>
                                            Gold rate unchanged from yesterday

                                            {{/if_eq}}

                                            {{/if_eq}}

                                        </span>
                                </div>
                            </div>

                            <div class="rate-chart">
                                <img src="/img/gold_graph.png" alt="">
                            </div>
                        </div>
                        {{/if}}
                        {{#if silverRate}}
