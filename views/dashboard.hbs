<script src="https://cdn.tailwindcss.com"></script>
<style>
    .otp-input::-webkit-outer-spin-button,
    .otp-input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .otp-input[type="number"] {
        -moz-appearance: textfield;
        /* Firefox */
    }

    .otp-input {
        border-radius: 0.75rem;
        border-width: 2px;
        border-color: #e5e7eb;
        outline-style: none;
        width: 3.5rem;
        height: 3.5rem;
        font-size: 1.25rem;
        line-height: 1.75rem;
        font-weight: 600;
        text-align: center;
        transition-property: all;
        background-color: rgba(255, 255, 255, 0.8);
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
        transition-duration: 300ms;
        backdrop-filter: blur(4px);
    }

    .otp-input:focus {
        border-color: #3b82f6;
        box-shadow: var(--tw-ring-inset) 0 0 0 calc(4px + var(--tw-ring-offset-width)) var(--tw-ring-color);
        --tw-ring-color: #dbeafe;
        background-color: #ffffff;
        transform: scale(1.05);
    }

    .otp-input:not(:placeholder-shown) {
        border-color: #34d399;
        background-color: #ecfdf5;
    }

    [type="submit"]:disabled,
    button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        background-image: linear-gradient(to right, #2a4aa7, #224485);
        transform: scale(1);
        box-shadow: none;
        transition: none;
    }

    button:disabled:hover {
        background-image: linear-gradient(to right, #224485, #2a4aa7);
        transform: scale(1);
        box-shadow: none;
        transition: none;
    }



    .grpsearch-input {
        width: 100%;
        padding: 0.35rem 1rem 0.35rem 1.75rem;
        border: 2px solid #e5e7eb;
        border-radius: 0.75rem;
        font-size: 1rem;
        outline: none;
        transition: all 0.3s ease;
    }

    .grpsearch-input:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
    }

    .grpsearch-icon {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: #6b7280;
    }

    .leave-group-btn {
        color: #fff;
        background-color: rgb(255, 46, 46);
        padding: 8px 16px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        transition: transform 0.3s;
        font-size: 12px;
    }

    @media (max-width: 768px) {
        .leave-group-btn {
            margin-left: 0px;
            margin-top: 10px;
        }
    }

    .kyc-required-btn {
        background-color: #2f95ff;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 20px;
        font-size: 16px;
        cursor: pointer;
        transition: background-color 0.3s, transform 0.3s;
        margin-top: 20px;
        font-weight: 500;
        margin-left: 35%;
    }

    /* live rates preview section */
    /* Live Rates and Business Preview Styles */
    .live-rates-preview,
    .business-preview {
        /*  border-left: 4px solid #2a4aa7;
        transition: all 0.3s ease; */

        background: #ffffff;
        border-radius: 18px;
        padding: 22px !important;
        border: 1px solid #edf1f7;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
        transition: all 0.3s ease;
    }

    .live-rates-preview:hover,
    .business-preview:hover {
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
    }

    .rate-item,
    .business-card {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 125px;
        border-radius: 16px;
        padding: 18px;
        position: relative;
        transition: all 0.3s ease;

        overflow: hidden;
        isolation: isolate;
    }

    .summary-card {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 16px;
        overflow: hidden;
    }

    .summary-content {
        flex: 1;
    }

    .rate-change.up {
        color: #16a34a;
    }

    .rate-change.down {
        color: #dc2626;
    }

    .rate-sub-details {
        margin-top: 12px;
        font-size: 14px;
        position: relative;
        z-index: 2;
    }

    .rate-sub-details p {
        margin-bottom: 4px;
        font-weight: 600;
        line-height: 1.4;
    }

    .rate-sub-details .get-value {
        color: #16a34a;
    }

    .rate-sub-details .give-value {
        color: #dc2626;
    }

    .business-logo {
        border: 2px solid #e5e7eb;
        transition: transform 0.3s ease;
    }

    .business-card:hover .business-logo {
        transform: scale(1.1);
    }

    .view-btn,
    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

    .view-btn:hover,
    .action-btn:hover {
        transform: translateY(-1px);
    }

    /* Responsive Adjustments */
    @media (max-width: 768px) {
        .grid-cols-4 {
            grid-template-columns: 1fr 1fr;
        }

        .live-rates-preview,
        .business-preview {
            padding: 12px;
        }

        .view-btn,
        .action-btn {
            padding: 2px 8px;
            font-size: 0.75rem;
        }
    }

    .summary-icon-wrap {
        width: 80px;
        height: 80px;
        min-width: 52px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .summary-icon-wrap img {
        width: 52px;
        height: 52px;
        object-fit: contain;
    }

    .summary-gold-card .summary-icon-wrap {
        background: #fff4cc;
    }

    .summary-silver-card .summary-icon-wrap {
        background: #f1f5f9;
    }

    .summary-cash-card .summary-icon-wrap {
        background: #dcfce7;
    }

    .summary-card {
        background: #ffffff;
        border: 1px solid #edf1f7;
    }

    .live-rates-preview .gold-card {
        background: linear-gradient(135deg, #fff7df, #fff3cc);
        border: 1px solid #f6df9e;
    }

    .live-rates-preview .silver-card {
        background: linear-gradient(135deg, #f5f5f5, #ebebeb);
        border: 1px solid #d8d8d8;
    }

    .rate-item:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08);
    }

    .rate-top {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        position: relative;
        z-index: 2;
    }

    .live-rates-preview .rate-item {
        align-items: flex-start;
    }

    .rate-icon {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .rate-label {
        font-size: 13px;
        font-weight: 600;
        color: #555;
        text-transform: uppercase;
    }

    .rate-value {
        font-size: 30px;
        font-weight: 700;
        color: #111827;
        margin: 6px 0;
        position: relative;
        z-index: 2;
        line-height: 1.2;
        word-break: break-word;
    }

    .rate-change {
        font-size: 14px;
        font-weight: 600;
    }

    .rate-chart {
        position: absolute;
        right: 12px;
        bottom: 0px;
        opacity: 1;
        background: transparent !important;
        z-index: 1;
    }

    .rate-chart img {
        width: 120px;
        height: auto;
        object-fit: contain;
        display: block;
    }

    @media (max-width:768px) {

        .live-rates-preview .grid {
            grid-template-columns: 1fr !important;
        }

        /*   .rate-value {
            font-size: 24px;
        } */

        .rate-item {
            min-height: 160px;
            padding: 16px;
        }

        .rate-chart {
            width: 65px;
            right: -5px;
            bottom: -5px;
            opacity: 0.08;
        }

        .rate-chart img {
            width: 75px;
            opacity: 0.9;
        }

        .rate-value {
            font-size: 22px;
            line-height: 1.2;
        }

        .live-rates-preview .grid {
            gap: 14px;
        }

        .rate-change {
            font-size: 11px;
            line-height: 1.4;
            padding-right: 45px;
            position: relative;
            z-index: 2;
        }

        .rate-sub-details {
            font-size: 12px;
            padding-right: 40px;
        }

        .rate-sub-details p {
            margin-bottom: 2px;
        }

        .rate-value {
            font-size: 22px;
        }
    }

    @media (min-width: 769px) and (max-width: 1024px) {

        .rate-chart {
            width: 65px;
            right: -5px;
            bottom: -5px;
            opacity: 0.08;
        }

        .rate-chart img {
            width: 75px;
            opacity: 0.9;
        }

        .rate-change {
            font-size: 13px;
            line-height: 1.4;
            padding-right: 70px;
            position: relative;
            z-index: 2;
        }

        .rate-item {
            overflow: hidden;
        }

        .rate-chart img {
            width: 70px;
        }
    }

    /* Welcome Banner */
    .welcome-banner {
        /*   background: linear-gradient(to left, #2a4aa7, #2f95ff); */
        background: linear-gradient(to right, #5d81ed, #2f95ff);
        color: white;
        padding: 24px;
        border-radius: 12px;
        margin-bottom: 30px;
        text-align: center;

        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 30px;
    }

    .welcome-left {
        flex: 1;
    }

    .welcome-right {
        flex: 0 0 auto;
        display: flex;
        justify-content: flex-end;
    }

    .welcome-right img {
        width: 320px;
        max-width: 100%;
        object-fit: contain;
    }

    .welcome-title {
        font-size: 2.5rem;
        margin-bottom: 14px;
        line-height: 1.2;
        font-weight: 700;
    }

    .welcome-text {
        color: rgba(255, 255, 255, 0.92);
        font-weight: 500;
    }

    .user-name {
        color: #f6f6f6;
        font-weight: 500;
    }

    .welcome-description {
        /* font-size: 1.1rem;*/
        margin-bottom: 16px;
    }

    .welcome-actions {
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .action-btn {
        background: white;
        color: #2a4aa7;
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: 500;
        text-decoration: none;
        transition: background-color 0.3s;
    }

    .action-btn:hover {
        background: #f0f2f5;
    }

    @media (max-width: 768px) {

        .welcome-banner {
            flex-direction: column-reverse;
            text-align: center;
            padding: 20px;
            gap: 20px;
        }

        .welcome-left {
            width: 100%;
        }

        .welcome-right {
            width: 100%;
            justify-content: center;
        }

        .welcome-right img {
            width: 220px;
        }

        .welcome-title {
            font-size: 1.8rem;
            line-height: 1.3;
        }

        .welcome-description {
            font-size: 14px;
            line-height: 1.6;
            padding: 0 5px;
        }

        .welcome-actions {
            flex-wrap: wrap;
            justify-content: center;
            gap: 10px;
        }

        .action-btn {
            width: auto;
            min-width: 170px;
            justify-content: center;
            padding: 12px 16px;
            font-size: 14px;
        }

        .grid-cols-4 {
            grid-template-columns: 1fr 1fr;
        }

        .live-rates-preview,
        .business-preview {
            padding: 12px;
        }

        .view-btn {
            background: transparent !important;
            padding: 0 !important;
            border: none !important;
            box-shadow: none !important;
            color: #2563eb !important;
            font-size: 13px;
            font-weight: 600;
        }

        .view-btn i {
            display: none;
        }
    }

    /* Discover community section */
    #discoverGroupsList,
    #myGroupsList {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    .group-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 14px;
        position: relative;

        display: flex;
        flex-direction: column;
        height: 100%;
    }

    /* TOP SECTION */
    .group-image {
        width: 70px;
        height: 70px;
        border-radius: 12px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .group-details {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    /* image + title */
    .group-title {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 10px;
    }

    /* description middle me */
    .group-description {
        font-size: 13px;
        color: #6b7280;
        line-height: 1.5;
        flex: 1;
        margin-bottom: 14px;
    }

    /* buttons bottom me */
    .join-group-btn,
    .manage-group-btn,
    .leave-group-btn,
    .joined-btn,
    .pending-btn {
        align-self: flex-start;
        margin-top: auto;
    }

    /* image + title ko same line me */
    .group-card .group-details::before {
        content: "";
    }

    .group-card img.group-image {
        margin-bottom: 10px;
    }

    /* dots */
    .group-actions {
        position: absolute;
        top: 10px;
        right: 10px;
    }

    .see-group-btn {
        white-space: nowrap;
    }

    #discoverGroupsList,
    #myGroupsList {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    /* MOBILE */
    @media (max-width: 768px) {

        #discoverGroupsList,
        #myGroupsList {
            grid-template-columns: 1fr;
        }
    }
</style>

<body data-user-id="{{user._id}}">

    {{> header}}

    <div class="main-container">
        <!-- Sidebar -->
        {{> sidebar}}

        <!-- Main Content -->

        <main class="flex-1 overflow-auto">
