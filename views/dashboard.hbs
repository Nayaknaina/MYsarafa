    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="/js/all.js"></script>
    <script>


        // Show notification
        function showNotification(message, type = 'info') {
            toastr.options = { timeOut: 3000, positionClass: 'toast-top-right' };
            if (type === 'success') toastr.success(message);
            else if (type === 'error') toastr.error(message);
            else toastr.info(message);
        }

        // Debounce function to limit API calls
        function debounce(func, wait) {
            let timeout;
            return function (...args) {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), wait);
            };
        }

        // Function to render groups
        function renderGroups(containerId, groups, noResultsId, isDiscover = false) {
            const container = document.getElementById(containerId);
            const noResults = document.getElementById(noResultsId);

            if (!container || !noResults) {
                console.error(`Cannot find container (${containerId}) or noResults (${noResultsId}) element`);
                showNotification('Error rendering groups. Please try again.', 'error');
                return;
            }


            const groupCards = container.querySelectorAll('.group-card');
            groupCards.forEach(card => card.remove());

            if (groups.length === 0) {
                noResults.style.display = 'block';
                return;
            }
            noResults.style.display = 'none';
            groups.forEach(group => {
                const groupCard = document.createElement('div');
                groupCard.className = 'group-card';
                groupCard.setAttribute('data-group-name', group.g_name);
                groupCard.innerHTML = `
                    <img src="${group.g_cover}" alt="${group.g_name} Image" class="group-image">
                    <div class="group-details">
                        <h3 class="group-title">${group.g_name}</h3>
                        <p class="group-description">
                            ${isDiscover ? `${group.description} Join this ${group.g_type} community to connect with others.` : `Manage your ${group.g_type} community with ${group.total_mem} members.`}
                        </p>
                        ${isDiscover ? `
                            ${group.isJoined ? '<button class="joined-btn" disabled>Joined</button>' :
                            group.isPending ? '<button class="pending-btn" disabled>Pending</button>' :
                                `<button class="join-group-btn" data-group-id="${group._id}">Join Community</button>`}
                        ` : `
                            ${group.membershipType === 'admin' ? `<button class="manage-group-btn" data-group-id="${group._id}">Manage Community</button>` : `<button class="leave-btn" data-group-id="${group._id}">Leave Community</button>`
                    }
                        `}
                        

                    </div>
                    <div class="group-actions">
                        <button class="more-options-btn" aria-label="More options">•••</button>
                        <div class="more-options-menu" style="display: none; position: absolute; right: 0; background: white; border: 1px solid #ddd; border-radius: 8px; padding: 8px;">
                            <button class="see-group-btn" data-group-id="${group._id}">See Group</button>
                        </div>
                    </div>
                `;
                container.appendChild(groupCard);
            });
        }

        // Function to fetch groups from backend
        async function fetchGroups(endpoint, query, containerId, noResultsId, isDiscover) {
            const loadingSpinner = document.getElementById(isDiscover ? 'discoverLoading' : 'myGroupsLoading');
            loadingSpinner.style.display = 'block';
            try {
                const response = await fetch(`${endpoint}?query=${encodeURIComponent(query)}`, {
                    method: 'GET',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include'
                });
                const result = await response.json();

                if (response.ok) {
                    renderGroups(containerId, result.groups, noResultsId, isDiscover);
                } else {
                    showNotification(result.message || 'Failed to fetch groups', 'error');
                }
            } catch (error) {
                console.error(`Error fetching ${isDiscover ? 'discover' : 'my'} groups:`, error);
                showNotification(`Error fetching groups: ${error.message}`, 'error');
            } finally {
                loadingSpinner.style.display = 'none';
            }
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', () => {
            // Initial rendering from server-side data
            // Discover groups search
            document.getElementById('discoverSearch').addEventListener('input', debounce((e) => {
                const query = e.target.value.trim();
                fetchGroups('/Groups/search/discover', query, 'discoverGroupsList', 'discoverNoResults', true);
            }, 300));

            // My groups search
            document.getElementById('myGroupsSearch').addEventListener('input', debounce((e) => {
                const query = e.target.value.trim();
                fetchGroups('/Groups/search/my', query, 'myGroupsList', 'myGroupsNoResults', false);
            }, 300));

            // Infinite scroll for business scroller
            const businessScroller = document.getElementById('businessScroller');
            if (businessScroller && businessScroller.children.length > 0) {
                const originalContent = businessScroller.innerHTML;
                businessScroller.addEventListener('scroll', () => {
                    if (businessScroller.scrollLeft + businessScroller.clientWidth >= businessScroller.scrollWidth - 10) {
                        // Near end: Append a clone of the original content
                        businessScroller.innerHTML += originalContent;
                    }
                });
            }
        });

        // Click on group title to navigate to group details
        document.querySelectorAll('.group-title').forEach(title => {
            title.style.cursor = 'pointer';
            title.addEventListener('click', () => {
                const groupId = title.closest('.group-card').querySelector('[data-group-id]')?.dataset.groupId;
                if (groupId) {
                    window.location.href = `/Groups/group-info/${groupId}`;
                }
            });
        });

        // 3 dots menu
        document.addEventListener('click', (e) => {
            if (e.target.classList.contains('more-options-btn')) {
                const menu = e.target.nextElementSibling;
                menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
            } else if (e.target.classList.contains('see-group-btn')) {
                const groupId = e.target.dataset.groupId;
                if (groupId) {
                    window.location.href = `/Groups/group-info/${groupId}`;
                }
            } else {
                document.querySelectorAll('.more-options-menu').forEach(menu => {
                    menu.style.display = 'none';
                });
            }
        });
    </script>
    
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Hide loader once the page content is fully loaded
        const loader = document.getElementById('globalLoader');
        loader.style.display = 'none';

        // Add click event listeners to all sidebar menu links
        const sidebarLinks = document.querySelectorAll('.sidebar .menu-item a');
        sidebarLinks.forEach(link => {
            link.addEventListener('click', function(e) {
                // Show loader immediately on click
                console.log('Link clicked, showing loader...');
                loader.style.display = 'flex';
            });
        });
    });
</script>

