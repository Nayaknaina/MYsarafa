<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sarafa Community Dashboard</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <link rel="canonical" href="https://app.mysarafa.com/">
</head>
<script src="https://cdn.tailwindcss.com"></script>
<style>
    .otp-input::-webkit-outer-spin-button,
    .otp-input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .otp-input[type="number"] {
        -moz-appearance: textfield;
        /* Firefox */
    }

    .otp-input {
        border-radius: 0.75rem;
        border-width: 2px;
        border-color: #e5e7eb;
        outline-style: none;
        width: 3.5rem;
        height: 3.5rem;
        font-size: 1.25rem;
        line-height: 1.75rem;
        font-weight: 600;
        text-align: center;
        transition-property: all;
        background-color: rgba(255, 255, 255, 0.8);
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
        transition-duration: 300ms;
        backdrop-filter: blur(4px);
    }

    .otp-input:focus {
        border-color: #3b82f6;
        box-shadow: var(--tw-ring-inset) 0 0 0 calc(4px + var(--tw-ring-offset-width)) var(--tw-ring-color);
        --tw-ring-color: #dbeafe;
        background-color: #ffffff;
        transform: scale(1.05);
    }

    .otp-input:not(:placeholder-shown) {
        border-color: #34d399;
        background-color: #ecfdf5;
    }

    [type="submit"]:disabled,
    button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        background-image: linear-gradient(to right, #2a4aa7, #224485);
        transform: scale(1);
        box-shadow: none;
        transition: none;
    }

    button:disabled:hover {
        background-image: linear-gradient(to right, #224485, #2a4aa7);
        transform: scale(1);
        box-shadow: none;
        transition: none;
    }

    

    .grpsearch-input {
        width: 100%;
        padding: 0.35rem 1rem 0.35rem 1.75rem;
        border: 2px solid #e5e7eb;
        border-radius: 0.75rem;
        font-size: 1rem;
        outline: none;
        transition: all 0.3s ease;
    }

    .grpsearch-input:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
    }

    .grpsearch-icon {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: #6b7280;
    }

    .leave-group-btn {
        color: #fff;
        background-color: rgb(255, 46, 46);
        padding: 8px 16px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        transition: transform 0.3s;
        font-size: 12px;
    }

    @media (max-width: 768px) {
        .leave-group-btn {
            margin-left: 0px;
            margin-top: 10px;
        }
    }

    .kyc-required-btn {
        background-color: #2f95ff;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 20px;
        font-size: 16px;
        cursor: pointer;
        transition: background-color 0.3s, transform 0.3s;
        margin-top: 20px;
        font-weight: 500;
        margin-left: 35%;
    }

    /* live rates preview section */
    /* Live Rates and Business Preview Styles */
    .live-rates-preview,
    .business-preview {
        border-left: 4px solid #2a4aa7;
        transition: all 0.3s ease;
    }

    .live-rates-preview:hover,
    .business-preview:hover {
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.1);
    }

    .rate-item,
    .business-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        min-height: 100px;
    }

    .rate-value {
        margin: 4px 0;
    }

    .rate-change.up {
        color: #28a745;
    }

    .rate-change.down {
        color: #dc3545;
    }

    .business-logo {
        border: 2px solid #e5e7eb;
        transition: transform 0.3s ease;
    }

    .business-card:hover .business-logo {
        transform: scale(1.1);
    }

    .view-btn,
    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: all 0.3s ease;
    }

    .view-btn:hover,
    .action-btn:hover {
        transform: translateY(-1px);
    }

    /* Responsive Adjustments */
    @media (max-width: 768px) {
        .grid-cols-4 {
            grid-template-columns: 1fr 1fr;
        }

        .live-rates-preview,
        .business-preview {
            padding: 12px;
        }

        .view-btn,
        .action-btn {
            padding: 2px 8px;
            font-size: 0.75rem;
        }
    }

    /* Welcome Banner */
    .welcome-banner {
        background: linear-gradient(to left, #2a4aa7, #2f95ff);
        color: white;
        padding: 24px;
        border-radius: 12px;
        margin-bottom: 30px;
        text-align: center;
    }

    .welcome-title {
        font-size: 2rem;
        margin-bottom: 12px;
    }

    .welcome-description {
        /* font-size: 1.1rem;*/
        margin-bottom: 16px;
    }

    .welcome-actions {
        display: flex;
        justify-content: center;
        gap: 12px;
    }

    .action-btn {
        background: white;
        color: #2a4aa7;
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: 500;
        text-decoration: none;
        transition: background-color 0.3s;
    }

    .action-btn:hover {
        background: #f0f2f5;
    }
</style>

<body data-user-id="{{user._id}}">
 
    {{> header}}

    <div class="main-container">
        <!-- Sidebar -->
        {{> sidebar}}

        <!-- Main Content -->
        
        <main class="flex-1 overflow-auto">
            <div class="main-content p-6" style="height: 80vh !important;">
                {{!-- <h1 class="page-title">Dashboard</h1> --}}

                {{#if pendingGroup}}
                <div id="duePaymentModal" class="modal-overlay" style="display: flex;">
                    <div class="modal-content">
                        <div class="modal-header">
                            <span style="font-size: 18px; font-weight: 600;">Payment Due</span>
                            <button class="modal-close-btn" id="closeDuePaymentModal">&times;</button>
                        </div>
                        <div class="modal-body">
                            <p style="font-size: 15px; color: #333; margin-bottom: 18px;">
                                Pay your pending payment.<br>
                                Your <strong>{{pendingGroup.g_name}}</strong> payment of
                                <strong>₹{{pendingGroup.amount}}</strong> is due.
                            </p> 
                            <div style="display: flex; gap: 10px;">
                                <button id="payNowBtn" data-group-id="{{pendingGroup._id}}"
                                    style="flex: 1; background: #2f95ff; color: #fff; border: none; border-radius: 8px; padding: 10px 0; font-size: 15px; font-weight: 500; cursor: pointer;"
                                    class="pay-now-btn">Pay Now</button>
                            </div>
                        </div>
                    </div>
                </div>
                {{/if}}

                <!-- Welcome Banner -->
                <section class="welcome-banner">
                    <h2 class="welcome-title">Welcome to MySarafa</h2>
                    <p class="welcome-description">Connect with sarafa communities, stay updated with live gold and silver
                        rates, list your business for visibility, and manage associations effortlessly.</p>
                    <div class="welcome-actions">
                        <a href="/rates/getRates" class="action-btn">View Live Rates</a>
                        <a href="/businesses/listUP" class="action-btn">List Your Business</a>
                        <a href="/Groups/community/" class="action-btn">Create Community</a>
                    </div>
                </section>

                <!-- Live Rates Preview -->
                <section class="live-rates-preview bg-white rounded-xl p-4 mb-6 shadow-md">
                    <div class="flex items-center justify-between mb-2">
                        <h2 class="text-lg font-semibold text-gray-800 flex items-center">
                            <i class="fas fa-chart-line mr-2 text-blue-500"></i> Live Gold & Silver Rates
                        </h2>
                        <a href="/rates/getRates"
                            class="view-btn inline-flex items-center px-3 py-1 bg-blue-600 text-white text-sm font-medium rounded-full hover:bg-blue-700 transition-colors">
                            <i class="fas fa-eye mr-1"></i> View All
                        </a>
                    </div>
                    <div class="grid grid-cols-2  gap-3">
                        {{#if goldRate}}
                        <div class="rate-item bg-gray-50 p-2 rounded-lg text-center hover:bg-gray-100 transition-colors">
                            <span class="text-xs text-gray-600">Gold (24K/10g)</span>
                            <p class="rate-value text-lg font-bold text-gray-900">₹{{goldRate.price_gram_24k}}</p>
                            <span class="rate-change {{goldRate.changes.price}} text-sm">
                                {{#if_eq goldRate.changes.price 'up'}}
                                <i class="fas fa-arrow-up mr-1"></i>
                                {{else}}
                                <i class="fas fa-arrow-down mr-1"></i>
                                {{/if_eq}}
                                {{goldRate.chp}}%
                            </span>
                        </div>
                        {{/if}}
                        {{#if silverRate}}
                        <div class="rate-item bg-gray-50 p-2 rounded-lg text-center hover:bg-gray-100 transition-colors">
                            <span class="text-xs text-gray-600">Silver (1kg)</span>
                            <p class="rate-value text-lg font-bold text-gray-900">₹{{silverRate.price}}</p>
                            <span class="rate-change {{silverRate.changes.price}} text-sm">
                                {{#if_eq silverRate.changes.price 'up'}}
                                <i class="fas fa-arrow-up mr-1"></i>
                                {{else}}
                                <i class="fas fa-arrow-down mr-1"></i>
                                {{/if_eq}}
                                {{silverRate.chp}}%
                            </span>
                        </div>
                        {{/if}}
                    </div>
                </section>

             
                {{> businessScroller businesses=featuredBusinesses showAddButton=isLeader}}
                
                <section class="live-rates-preview bg-white rounded-xl p-4 mb-6 shadow-md">
                <div class="flex items-center justify-between mb-2">
                    <h2 class="text-lg font-semibold text-gray-800 flex items-center">
                        <i class="fas fa-wallet mr-2 text-yellow-600"></i> Gold, Silver & Cash Summary
                    </h2>
                    <a href="/rates/getRates" class="view-btn inline-flex items-center px-3 py-1 bg-blue-600 text-white text-sm font-medium rounded-full hover:bg-blue-700 transition-colors">
                        <i class="fas fa-eye mr-1"></i> + Add Entry
                    </a>
                </div>

                <div class="grid grid-cols-3 gap-3">

                    {{!-- GOLD CARD --}}
                    <div class="rate-item bg-gray-50 p-3 rounded-lg text-center hover:bg-gray-100 transition-colors">
                        <span class="text-xs text-gray-600">Gold Total (gram)</span>
                            <p class="rate-value text-lg font-bold 
                            {{#if (gt totals.totalGold 0)}}text-green-600
                            {{else}}{{#if (lt totals.totalGold 0)}}text-red-600
                            {{else}}text-gray-800{{/if}}{{/if}}">
                            {{#if (gt totals.totalGold 0)}}+{{/if}}{{totals.totalGold}}
                            </p>

                        <div class="mt-3 text-sm">
                            <p class="text-green-600 font-medium">You Get: {{totals.goldGet}}</p>
                            <p class="text-red-600 font-medium">You Give: {{totals.goldGive}}</p>
                        </div>
                    </div>

                    {{!-- SILVER CARD --}}
                    <div class="rate-item bg-gray-50 p-3 rounded-lg text-center hover:bg-gray-100 transition-colors">
                        <span class="text-xs text-gray-600">Silver Total (gram)</span>
                        {{!-- <p class="rate-value text-lg font-bold text-gray-900">{{totals.silverTotal}}</p> --}}

                            <p class="rate-value text-lg font-bold 
                            {{#if (gt totals.totalSilver 0)}}text-green-600
                            {{else}}{{#if (lt totals.totalSilver 0)}}text-red-600
                            {{else}}text-gray-800{{/if}}{{/if}}">
                            {{#if (gt totals.totalSilver 0)}}+{{/if}}{{totals.totalSilver}}
                            </p>

                        <div class="mt-3 text-sm">
                            <p class="text-green-600 font-medium">You Get: {{totals.silverGet}}</p>
                            <p class="text-red-600 font-medium">You Give: {{totals.silverGive}}</p>
                        </div>
                    </div>

                    {{!-- CASH CARD --}}
                    <div class="rate-item bg-gray-50 p-3 rounded-lg text-center hover:bg-gray-100 transition-colors">
                        <span class="text-xs text-gray-600">Cash Total (₹)</span>
                        {{!-- <p class="rate-value text-lg font-bold text-gray-900">{{totals.cashTotal}}</p> --}}
                        <p class="rate-value text-lg font-bold 
                            {{#if (gt totals.totalCash 0)}}text-green-600
                            {{else}}{{#if (lt totals.totalCash 0)}}text-red-600
                            {{else}}text-gray-800{{/if}}{{/if}}">
                            {{#if (gt totals.totalCash 0)}}+{{/if}}{{totals.totalCash}}
                            </p>

                        <div class="mt-3 text-sm">
                            <p class="text-green-600 font-medium">You Get: {{totals.cashGet}}</p>
                            <p class="text-red-600 font-medium">You Give: {{totals.cashGive}}</p>
                        </div>
                    </div>

                </div>
                </section>

                <!-- Group Discovery and My Groups Section -->
                <section class="group-discovery-section">
                    <div class="group-discovery-container">

                        <div class="discover-groups">
                            <div class="flex justify-between items-center mb-4">
                                <h2 class="section-title">Discover Community</h2>
                                <div class="search-container w-1/3">
                                    <i class="fas fa-search grpsearch-icon"></i>
                                    <input type="text" id="discoverSearch" class="grpsearch-input"
                                        placeholder="Search communities...">
                                    <div id="discoverLoading" class="loading-spinner"></div>
                                </div>
                            </div>
                            <div id="discoverGroupsList">
                                <p id="discoverNoResults" style="display: none;">No public communities available to join.
                                </p>
                                {{#each discoverGroups}}
                                <div class="group-card" data-group-name="{{this.g_name}}">
                                    <img src="{{this.g_cover}}" alt="{{this.g_name}} Image" class="group-image">
                                    <div class="group-details">
                                        <h3 class="group-title">{{this.g_name}}</h3>
                                        <p class="group-description">{{this.description}} Join this {{this.g_type}}
                                            community to connect with others.</p>
                                        {{#if isJoined}}
                                        <button class="joined-btn" disabled>Joined</button>
                                        {{else if isPending}}
                                        <button class="pending-btn" disabled>Pending</button>
                                        {{else}}
                                        <button class="join-group-btn" data-group-id="{{_id}}">Join Community</button>
                                        {{/if}}
                                    </div>
                                    <div class="group-actions">
                                        <button class="more-options-btn" aria-label="More options">•••</button>
                                        <div class="more-options-menu"
                                            style="display: none; position: absolute; right: 0; background: white; border: 1px solid #ddd; border-radius: 8px; padding: 8px;">
                                            <button class="see-group-btn" data-group-id="{{_id}}">See Group</button>
                                        </div>
                                    </div>
                                </div>
                                {{/each}}
                            </div>
                        </div>

                        <!-- My Groups (User's own groups) -->
                        <div class="my-groups">
                            <div class="flex justify-between items-center mb-4">
                                <h2 class="section-title">My Communities</h2>
                                <div class="search-container w-1/3">
                                    <i class="fas fa-search grpsearch-icon"></i>
                                    <input type="text" id="myGroupsSearch" class="grpsearch-input"
                                        placeholder="Search my communities...">
                                    <div id="myGroupsLoading" class="loading-spinner"></div>
                                </div>
                            </div>
                            <div id="myGroupsList">
                                <p id="myGroupsNoResults" style="display:none;">You haven't created or joined any
                                    communities yet.</p>

                                {{#each myGroups}}
                                <div class="group-card">
                                    <img src="{{this.g_cover}}" alt="{{this.g_name}} Image" class="group-image">
                                    <div class="group-details">
                                        <h3 class="group-title">{{this.g_name}}</h3>
                                        <p class="group-description">Manage your {{this.g_type}} community with
                                            {{this.total_mem}} members.</p>
                                        {{!-- <button class="manage-group-btn" data-group-id="{{this._id}}">Manage
                                            Community</button> --}}
                                        {{#if (eq this.membershipType "admin")}}
                                        <button class="manage-group-btn" data-group-id="{{this._id}}">Manage
                                            Community</button>
                                        {{else}}
                                        <button class="leave-group-btn" data-group-id="{{this._id}}">Leave
                                            Community</button>
                                        {{/if}}


                                    </div>
                                    <div class="group-actions">
                                        <button class="more-options-btn" aria-label="More options">•••</button>
                                        <div class="more-options-menu"
                                            style="display: none; position: absolute; right: 0; background: white; border: 1px solid #ddd; border-radius: 8px; padding: 8px;">
                                            <button class="see-group-btn" data-group-id="{{_id}}">See Group</button>
                                        </div>
                                    </div>
                                </div>

                                {{/each}}
                            </div>
                        </div>
                    </div>
                </section>


                <div id="verifyMobileModal"
                    class="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4 z-50"
                    style="display: none;">
                    <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md">
                        <div class="text-center mb-8">
                            <div
                                class="w-20 h-20 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
                                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M5.121 17.804A7 7 0 0112 15a7 7 0 016.879 2.804M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            </div>
                            <h2 class="text-3xl font-bold text-gray-800 mb-2">Complete Your Profile</h2>
                            <p class="text-gray-600 text-sm">Verify your mobile number to proceed</p>
                        </div>

                        <form id="verifyMobileForm" class="space-y-8">
                            {{#unless user.mobile_verified}}
                            <div id="mobileSection" class="space-y-4">
                                <input type="tel" id="mobile_no" name="mobile_no"
                                    class="w-full border-2 border-gray-200 rounded-xl p-4 text-lg font-semibold focus:border-blue-500 focus:ring-4 focus:ring-blue-200 outline-none transition-all"
                                    placeholder="Enter 10-digit mobile number" required>
                                <button type="button" id="sendOtpBtn"
                                    class="w-full bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-semibold py-4 px-6 rounded-2xl transition-all duration-300 transform hover:scale-105 hover:shadow-xl focus:outline-none focus:ring-4 focus:ring-blue-200"
                                    disabled>
                                    <span class="flex items-center justify-center space-x-2">
                                        <span>Send OTP</span>
                                    </span>
                                </button>
                                <p class="error text-red-600 text-sm text-center" id="mobileError" style="display: none;">
                                </p>
                                <div id="otpSection" class="flex justify-center space-x-0 hidden">
                                    <input type="number" class="otp-input" maxlength="1" min="0" max="9" placeholder=""
                                        autocomplete="off">
                                    <input type="number" class="otp-input" maxlength="1" min="0" max="9" placeholder=""
                                        autocomplete="off">
                                    <input type="number" class="otp-input" maxlength="1" min="0" max="9" placeholder=""
                                        autocomplete="off">
                                    <input type="number" class="otp-input" maxlength="1" min="0" max="9" placeholder=""
                                        autocomplete="off">
                                    <input type="number" class="otp-input" maxlength="1" min="0" max="9" placeholder=""
                                        autocomplete="off">
                                    <input type="number" class="otp-input" maxlength="1" min="0" max="9" placeholder=""
                                        autocomplete="off">
                                </div>
                                <button type="button" id="verifyOtpBtn"
                                    class="w-full bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-semibold py-4 px-6 rounded-2xl transition-all duration-300 transform hover:scale-105 hover:shadow-xl focus:outline-none focus:ring-4 focus:ring-blue-200 hidden"
                                    disabled>
                                    <span class="flex items-center justify-center space-x-2">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M5 13l4 4L19 7"></path>
                                        </svg>
                                        <span>Verify Code</span>
                                    </span>
                                </button>
                                <div class="text-center hidden" id="resendSection">
                                    <p class="text-gray-600 text-sm mb-2">Didn't receive the code?</p>
                                    <button type="button" id="resendOtpBtn"
                                        class="text-blue-600 font-medium hover:text-blue-800 transition-colors duration-200 underline underline-offset-2">
                                        Resend code
                                    </button>
                                </div>
                            </div>
                            {{/unless}}
                            {{#if user.mobile_verified}}
                            {{#unless user.has_password}}
                            <div id="passwordSection" class="space-y-4">
                                <label for="newPassword" class="block text-sm font-medium text-gray-700">New
                                    Password</label>
                                <input type="password" id="newPassword" name="password"
                                    class="w-full border-2 border-gray-200 rounded-xl p-4 text-lg font-semibold focus:border-blue-500 focus:ring-4 focus:ring-blue-200 outline-none transition-all"
                                    placeholder="Enter new password" required>
                                <label for="confirmPassword" class="block text-sm font-medium text-gray-700">Confirm
                                    Password</label>
                                <input type="password" id="confirmPassword" name="confirmPassword"
                                    class="w-full border-2 border-gray-200 rounded-xl p-4 text-lg font-semibold focus:border-blue-500 focus:ring-4 focus:ring-blue-200 outline-none transition-all"
                                    placeholder="Confirm password" required>
                                <button type="submit" id="setPasswordBtn"
                                    class="w-full bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-semibold py-4 px-6 rounded-2xl transition-all duration-300 transform hover:scale-105 hover:shadow-xl focus:outline-none focus:ring-4 focus:ring-blue-200">
                                    <span class="flex items-center justify-center space-x-2">
                                        <span>Set Password</span>
                                    </span>
                                </button>
                                <p class="error text-red-600 text-sm text-center" id="passwordError" style="display: none;">
                                </p>
                            </div>
                            {{/unless}}
                            {{/if}}
                        </form>
                    </div>

                    <!-- OTP Success/Error Modal -->
                    <div id="otpModal"
                        class="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4 z-50 opacity-0 invisible transition-all duration-300">
                        <div class="bg-white rounded-3xl shadow-2xl p-8 w-full max-w-md transform scale-75 transition-all duration-300"
                            id="modalContent">
                            <div class="text-center">
                                <div id="success-code" class="hidden">
                                    <div
