                                    {{!-- <span class="rate-change {{silverRate.changes.price}}">
                                        {{#if_eq silverRate.changes.price 'up'}}
                                        <i class="fas fa-arrow-up"></i>
                                        {{else}}
                                        <i class="fas fa-arrow-down"></i>
                                        {{/if_eq}}
